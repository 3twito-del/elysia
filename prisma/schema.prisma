  key         String                      @unique
  name        String
  description String?
  rule        Json?
  isSystem    Boolean                     @default(true)
  memberships CustomerSegmentMembership[]
  campaigns   Campaign[]
  journeys    Journey[]
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
}

