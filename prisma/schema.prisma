generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductAvailabilityMode {
  READY_TO_ORDER
  MADE_TO_ORDER
  CONSULTATION
}

enum ProductSource {
  OWN
  DROPSHIP_SHOPIFY
}

enum MediaKind {
  IMAGE
  VIDEO
  TRY_ON_REFERENCE
}

enum ProductMediaRole {
  PRIMARY
  ALTERNATE
  SCALE
  CONSTRUCTION
  MATERIAL
  CONTEXT
}

/// B-07 asset governance (docs/TASKS.md): where a media asset originated.
enum MediaProvenance {
  SUPPLIER_FEED
  OWNER_UPLOAD
  AI_GENERATED
  STOCK_LICENSED
  UNKNOWN
}

/// B-07 asset governance: rights status for using a media asset publicly.
enum MediaLicenseStatus {
  OWNED
  SUPPLIER_GRANTED
  LICENSED
  NEEDS_REVIEW
  UNKNOWN
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  READY_FOR_PICKUP
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

// ADR 0009 — who legally sold the order and therefore which accounting path
// it may take. Only OWN_SALE may ever post product-sale revenue to the GL.
// UNKNOWN_BLOCKED is the fail-closed default: a creation path that does not
// declare its treatment is blocked from the books.
enum FinancialTreatment {
  OWN_SALE
  AGENCY_DROPSHIP
  SUPPLIER_MOR_REFERENCE
  COMMISSION_ONLY
  UNKNOWN_BLOCKED
}

enum FulfillmentMethod {
  DELIVERY
  PICKUP
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OtpChannel {
  EMAIL
  SMS
}

enum BranchKind {
  ONLINE
  PHYSICAL
}

enum ServiceRequestStatus {
  NEW
  IN_REVIEW
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
}

enum ServiceContactPreference {
  EMAIL
  PHONE
  WHATSAPP
  ANY
}

enum AdminPermission {
  SYSTEM
  BLOG
  BLOG_READ
  BLOG_WRITE
  CATALOG
  CATALOG_READ
  CATALOG_WRITE
  INVENTORY
  INVENTORY_READ
  INVENTORY_WRITE
  ORDERS
  ORDERS_READ
  ORDERS_WRITE
  ORDERS_REFUND
  CUSTOMER_SERVICE
  CUSTOMER_VIEW
  CUSTOMER_WRITE
  ANALYTICS_READ
  CRM_READ
  CRM_WRITE
  ERP_READ
  ERP_WRITE
  FINANCE_READ
  FINANCE_WRITE
  MARKETING_WRITE
  OPERATIONS_WRITE
  PERFORMANCE_WRITE
  POS_WRITE
  PROJECTS_WRITE
  REPORTS_WRITE
  WORKFLOW_WRITE
  WORKSPACE_WRITE
  SYSTEM_CONFIG
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum OutboxEventStatus {
  PENDING
  PUBLISHED
  PROCESSING
  PROCESSED
  FAILED
  // ADR 0003/0007 — retry budget exhausted; stops retrying and becomes a
  // loud operational fact for the invariant sweep instead of silent churn.
  DEAD_LETTER
}

enum JobRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  customer      Customer?
  adminUser     AdminUser?
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Collection {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  description  String?
  heroImageUrl String?
  isFeatured   Boolean   @default(false)
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Material {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  products Product[]
}

model Stone {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  products Product[]
}

model Product {
  id                          String                   @id @default(cuid())
  slug                        String                   @unique
  sku                         String                   @unique
  name                        String
  shortDescription            String
  description                 String
  status                      ProductStatus            @default(DRAFT)
  categoryId                  String
  materialId                  String
  stoneId                     String?
  basePrice                   Decimal                  @db.Decimal(10, 2)
  availabilityMode            ProductAvailabilityMode  @default(READY_TO_ORDER)
  source                      ProductSource            @default(OWN)
  externalProvider            String?
  externalProductId           String?
  externalHandle              String?
  supplierKey                 String?
  externalSyncedAt            DateTime?
  commerceHighlights          String[]                 @default([])
  deliveryPromise             String?
  returnPolicy                String?
  careInstructions            String?
  warranty                    String?
  countryOfManufacture        String?
  manufacturerOrImporter      String?
  materialDetails             String?
  measurements                String?
  stoneDetails                String?
  factSourceReference         String?
  factVerifiedAt              DateTime?
  factVerifiedBy              String?
  /// J-10 content governance: when this fact verification must be re-reviewed.
  factVerificationExpiresAt   DateTime?
  policySourceReference       String?
  policyVerifiedAt            DateTime?
  policyVerifiedBy            String?
  /// J-10 content governance: when this policy verification must be re-reviewed.
  policyVerificationExpiresAt DateTime?
  tags                        String[]
  category                    Category                 @relation(fields: [categoryId], references: [id])
  material                    Material                 @relation(fields: [materialId], references: [id])
  stone                       Stone?                   @relation(fields: [stoneId], references: [id])
  collections                 Collection[]
  variants                    ProductVariant[]
  media                       ProductMedia[]
  searchEmbeddings            ProductSearchEmbedding[]
  pushInterests               ProductPushInterest[]
  blogPosts                   BlogPost[]
  searchEvents                SearchEvent[]
  viewEvents                  ProductViewEvent[]
  clickEvents                 ProductClickEvent[]
  analyticsEvents             AnalyticsEvent[]
  dailyMetrics                ProductDailyMetric[]
  purchaseOrderItems          PurchaseOrderItem[]
  costSnapshots               ProductCostSnapshot[]
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  @@index([status])
  @@index([source])
  @@index([externalProvider, externalProductId])
  @@index([supplierKey])
  @@index([categoryId])
  @@index([materialId])
}

model ProductSearchEmbedding {
  id         String   @id @default(cuid())
  productId  String
  model      String
  dimension  Int
  sourceHash String
  vector     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, model, dimension])
  @@index([model, dimension])
  @@index([sourceHash])
}

model ProductVariant {
  id                  String                @id @default(cuid())
  productId           String
  sku                 String                @unique
  name                String
  size                String?
  metalColor          String?
  stoneColor          String?
  priceDelta          Decimal               @default(0) @db.Decimal(10, 2)
  isDefault           Boolean               @default(false)
  externalVariantId   String?
  /// ADR 0012 display truth: last successful click-out live verification.
  lastLiveVerifiedAt  DateTime?
  product             Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices              Price[]
  inventoryItems      InventoryItem[]
  inventoryLedgers    InventoryLedger[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  goodsReceipts       GoodsReceipt[]
  costSnapshots       ProductCostSnapshot[]
  wishlistItems       WishlistItem[]
  tryOnSessions       TryOnSession[]
  stockTransferLines  StockTransferLine[]
  inventoryCountLines InventoryCountLine[]
  finishedBoms        BillOfMaterials[]     @relation("BomFinished")
  bomComponents       BomComponent[]        @relation("BomComponent")

  @@index([productId])
  @@index([externalVariantId])
}

model Price {
  id        String         @id @default(cuid())
  variantId String
  currency  String         @default("ILS")
  amount    Decimal        @db.Decimal(10, 2)
  compareAt Decimal?       @db.Decimal(10, 2)
  validFrom DateTime       @default(now())
  validTo   DateTime?
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, validFrom])
}

model ProductMedia {
  id               String             @id @default(cuid())
  productId        String
  kind             MediaKind          @default(IMAGE)
  role             ProductMediaRole?
  url              String
  alt              String
  cloudinaryId     String?
  width            Int?
  height           Int?
  isPrimary        Boolean            @default(false)
  sortOrder        Int                @default(0)
  /// B-07 asset governance: where this asset came from; UNKNOWN until reviewed.
  provenance       MediaProvenance    @default(UNKNOWN)
  /// B-07 asset governance: rights status for public use; UNKNOWN until reviewed.
  licenseStatus    MediaLicenseStatus @default(UNKNOWN)
  licenseExpiresAt DateTime?
  /// B-07: AI/synthetically generated imagery must be labeled, never silently
  /// presented as real product photography.
  isGenerated      Boolean            @default(false)
  /// Set when an admin explicitly clears a generated asset for public use.
  approvedAt       DateTime?
  approvedBy       String?
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([productId, role])
}

model Branch {
  id                String            @id @default(cuid())
  slug              String            @unique
  name              String
  address           String
  city              String
  phone             String
  whatsapp          String?
  latitude          Float?
  longitude         Float?
  openingHours      Json
  services          String[]
  kind              BranchKind        @default(PHYSICAL)
  isApproved        Boolean           @default(false)
  isPublic          Boolean           @default(false)
  isActive          Boolean           @default(true)
  sortOrder         Int               @default(0)
  /// owning legal entity for GL attribution (ENT); null = base entity
  entityId          String?
  inventoryItems    InventoryItem[]
  inventoryLedgers  InventoryLedger[]
  appointments      Appointment[]
  orders            Order[]
  goodsReceipts     GoodsReceipt[]
  stockTransfersOut StockTransfer[]   @relation("StockTransferSource")
  stockTransfersIn  StockTransfer[]   @relation("StockTransferDest")
  inventoryCounts   InventoryCount[]

  @@index([kind, isApproved, isPublic, isActive, sortOrder])
  @@index([entityId])
}

model ServiceSettings {
  id                      String   @id @default("default")
  phoneE164               String   @default("+972000000000")
  displayPhone            String   @default("05X-XXXXXXX")
  serviceEmail            String   @default("support@example.com")
  physicalBranchesEnabled Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model ContactTopic {
  id             String           @id @default(cuid())
  slug           String           @unique
  label          String
  description    String?
  recipientEmail String?
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  requests       ServiceRequest[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([isActive, sortOrder])
}

model ServiceRequest {
  id                   String                     @id @default(cuid())
  topicId              String?
  topic                ContactTopic?              @relation(fields: [topicId], references: [id], onDelete: SetNull)
  customerId           String?
  customer             Customer?                  @relation(fields: [customerId], references: [id])
  status               ServiceRequestStatus       @default(NEW)
  name                 String
  phone                String
  email                String
  orderNumber          String?
  productReference     String?
  preferredContact     ServiceContactPreference   @default(ANY)
  preferredContactTime String?
  message              String
  adminNotes           String?
  /// SLA priority: LOW | NORMAL | HIGH | URGENT
  priority             String                     @default("NORMAL")
  assignedAdminUserId  String?
  firstRespondedAt     DateTime?
  resolvedAt           DateTime?
  attachments          ServiceRequestAttachment[]
  events               ServiceRequestEvent[]
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([status, createdAt])
  @@index([status, priority])
  @@index([topicId])
  @@index([email])
  @@index([phone])
  @@index([customerId])
}

model ServiceRequestAttachment {
  id               String         @id @default(cuid())
  serviceRequestId String
  provider         String
  publicId         String
  secureUrl        String
  originalFilename String
  contentType      String
  bytes            Int
  width            Int?
  height           Int?
  request          ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@index([serviceRequestId])
}

/// H-05 service case timeline: the shared high-level history a customer may
/// see (visibility CUSTOMER) alongside internal-only entries (visibility
/// INTERNAL) that never leave the admin surface. NOTE/CUSTOMER_MESSAGE kinds
/// are modeled now for forward compatibility but not yet written by any
/// caller -- only RECEIVED (on creation) and STATUS_CHANGED (on an admin
/// status update) are populated today.
model ServiceRequestEvent {
  id               String                        @id @default(cuid())
  serviceRequestId String
  request          ServiceRequest                @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  kind             ServiceRequestEventKind
  visibility       ServiceRequestEventVisibility @default(CUSTOMER)
  status           ServiceRequestStatus?
  message          String?
  createdAt        DateTime                      @default(now())

  @@index([serviceRequestId, createdAt])
}

enum ServiceRequestEventKind {
  RECEIVED
  STATUS_CHANGED
  NOTE
  CUSTOMER_MESSAGE
}

enum ServiceRequestEventVisibility {
  CUSTOMER
  INTERNAL
}

model InventoryItem {
  id           String         @id @default(cuid())
  branchId     String
  variantId    String
  quantity     Int            @default(0)
  reserved     Int            @default(0)
  safetyStock  Int            @default(0)
  /// reorder trigger (0 = no policy); when net available drops to/below it, reorder
  reorderPoint Int            @default(0)
  /// replenish-up-to target level for reorder suggestions
  targetLevel  Int            @default(0)
  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  updatedAt    DateTime       @updatedAt

  @@unique([branchId, variantId])
  @@index([variantId])
}

model InventoryReservation {
  id         String    @id @default(cuid())
  branchId   String
  variantId  String
  quantity   Int
  cartId     String?
  orderId    String?
  expiresAt  DateTime
  releasedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([branchId, variantId])
  @@index([cartId])
  @@index([orderId])
}

model InventoryLedger {
  id        String         @id @default(cuid())
  branchId  String
  variantId String
  delta     Int
  reason    String
  reference String?
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([branchId, variantId])
  @@index([createdAt])
}

/// A branch-to-branch stock movement. Completing it atomically decrements the
/// source InventoryItem, increments the destination, and writes paired
/// InventoryLedger entries (transfer_out / transfer_in).
model StockTransfer {
  id             String              @id @default(cuid())
  transferNumber String              @unique
  sourceBranchId String
  destBranchId   String
  /// DRAFT | COMPLETED | CANCELLED
  status         String              @default("DRAFT")
  notes          String?
  completedAt    DateTime?
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  sourceBranch   Branch              @relation("StockTransferSource", fields: [sourceBranchId], references: [id], onDelete: Restrict)
  destBranch     Branch              @relation("StockTransferDest", fields: [destBranchId], references: [id], onDelete: Restrict)
  lines          StockTransferLine[]

  @@index([status])
  @@index([sourceBranchId])
  @@index([destBranchId])
}

model StockTransferLine {
  id         String         @id @default(cuid())
  transferId String
  variantId  String
  quantity   Int
  transfer   StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@index([variantId])
}

/// A cycle-count session for a branch. Completing it snapshots the book quantity
/// per line, sets InventoryItem to the counted quantity, and writes a
/// cycle_count_adjustment InventoryLedger entry for any variance.
model InventoryCount {
  id          String               @id @default(cuid())
  countNumber String               @unique
  branchId    String
  /// DRAFT | COMPLETED | CANCELLED
  status      String               @default("DRAFT")
  notes       String?
  countedById String?
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  branch      Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  lines       InventoryCountLine[]

  @@index([status])
  @@index([branchId])
}

model InventoryCountLine {
  id         String         @id @default(cuid())
  countId    String
  variantId  String
  countedQty Int
  /// Book quantity captured at completion (null while DRAFT).
  bookQty    Int?
  count      InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([countId])
  @@index([variantId])
}

/// A capitalised fixed asset, depreciated straight-line into the GL each month
/// (FIN-FA). `accumulatedDepreciation` is the running total; status moves to
/// FULLY_DEPRECIATED once the depreciable base (cost − salvage) is exhausted.
model FixedAsset {
  id                      String                   @id @default(cuid())
  assetNumber             String                   @unique
  name                    String
  category                String?
  acquisitionCost         Decimal                  @db.Decimal(14, 2)
  salvageValue            Decimal                  @default(0) @db.Decimal(14, 2)
  usefulLifeMonths        Int
  acquiredAt              DateTime                 @db.Date
  /// ACTIVE | FULLY_DEPRECIATED | DISPOSED
  status                  String                   @default("ACTIVE")
  accumulatedDepreciation Decimal                  @default(0) @db.Decimal(14, 2)
  lastDepreciatedPeriod   String?
  branchId                String?
  notes                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  depreciationEntries     FixedAssetDepreciation[]
  maintenanceSchedules    MaintenanceSchedule[]

  @@index([status])
}

/// A preventive-maintenance schedule for a fixed asset (FIN-FA-004): recurring
/// service at a fixed interval, tracking the next due date.
model MaintenanceSchedule {
  id             String     @id @default(cuid())
  fixedAssetId   String
  title          String
  intervalDays   Int
  lastServicedAt DateTime?  @db.Date
  nextDueAt      DateTime   @db.Date
  /// ACTIVE | PAUSED
  status         String     @default("ACTIVE")
  notes          String?
  asset          FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status, nextDueAt])
  @@index([fixedAssetId])
}

/// An employee for HR and payroll (HR master).
model Employee {
  id             String              @id @default(cuid())
  employeeNumber String              @unique
  firstName      String
  lastName       String
  email          String?
  role           String?
  department     String?
  monthlyGross   Decimal             @db.Decimal(12, 2)
  /// ACTIVE | TERMINATED
  status         String              @default("ACTIVE")
  hiredAt        DateTime            @db.Date
  branchId       String?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  payslips       Payslip[]
  expenseClaims  ExpenseClaim[]
  reviews        PerformanceReview[]
  goals          PerformanceGoal[]
  attendance     AttendanceEntry[]
  leaveRequests  LeaveRequest[]

  @@index([status])
}

/// A clock-in/out attendance record for an employee (HR-002).
model AttendanceEntry {
  id           String    @id @default(cuid())
  employeeId   String
  workDate     DateTime  @db.Date
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int       @default(0)
  notes        String?
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([employeeId, workDate])
}

/// An employee leave request (HR-002): vacation / sick / unpaid.
model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  /// VACATION | SICK | UNPAID
  type       String   @default("VACATION")
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  days       Int
  /// PENDING | APPROVED | REJECTED
  status     String   @default("PENDING")
  notes      String?
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId, status])
  @@index([status])
}

/// A performance review for an employee in a cycle (HRX).
model PerformanceReview {
  id         String   @id @default(cuid())
  employeeId String
  cycle      String
  rating     Int      @default(3)
  /// DRAFT | SUBMITTED | ACKNOWLEDGED
  status     String   @default("DRAFT")
  summary    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, cycle])
}

/// A performance / development goal for an employee (HRX).
model PerformanceGoal {
  id         String    @id @default(cuid())
  employeeId String
  title      String
  /// OPEN | IN_PROGRESS | DONE
  status     String    @default("OPEN")
  progress   Int       @default(0)
  dueDate    DateTime? @db.Date
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
}

/// An employee expense claim; approving it posts Dr General Expense / Cr Cash.
model ExpenseClaim {
  id             String    @id @default(cuid())
  claimNumber    String    @unique
  employeeId     String?
  description    String
  category       String?
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @default("ILS")
  /// SUBMITTED | APPROVED | REJECTED
  status         String    @default("SUBMITTED")
  incurredAt     DateTime  @db.Date
  notes          String?
  journalEntryId String?
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  employee       Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([employeeId])
}

/// A budgeted amount for one account in one period ("YYYY-MM"), compared to GL.
model BudgetLine {
  id          String   @id @default(cuid())
  period      String
  accountCode String
  amount      Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([period, accountCode])
  @@index([period])
}

/// A monthly payroll run posting salaries to the GL (idempotent per period).
model PayrollRun {
  id             String    @id @default(cuid())
  period         String    @unique
  /// DRAFT | POSTED
  status         String    @default("DRAFT")
  grossTotal     Decimal   @default(0) @db.Decimal(14, 2)
  netTotal       Decimal   @default(0) @db.Decimal(14, 2)
  journalEntryId String?
  postedById     String?
  postedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payslips       Payslip[]
}

/// One employee's payslip within a payroll run.
model Payslip {
  id             String     @id @default(cuid())
  payrollRunId   String
  employeeId     String
  gross          Decimal    @db.Decimal(12, 2)
  incomeTax      Decimal    @default(0) @db.Decimal(12, 2)
  socialSecurity Decimal    @default(0) @db.Decimal(12, 2)
  net            Decimal    @db.Decimal(12, 2)
  run            PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([payrollRunId])
  @@index([employeeId])
}

/// One month's depreciation charge for a fixed asset (idempotent per period).
model FixedAssetDepreciation {
  id             String     @id @default(cuid())
  fixedAssetId   String
  period         String
  amount         Decimal    @db.Decimal(14, 2)
  journalEntryId String?
  createdAt      DateTime   @default(now())
  fixedAsset     FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@unique([fixedAssetId, period])
  @@index([fixedAssetId])
}

/// A bill of materials: the components (and quantities) needed to produce one
/// unit of a finished product variant (PP).
model BillOfMaterials {
  id               String         @id @default(cuid())
  productVariantId String
  name             String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  finishedVariant  ProductVariant @relation("BomFinished", fields: [productVariantId], references: [id], onDelete: Cascade)
  components       BomComponent[]
  workOrders       WorkOrder[]

  @@index([productVariantId])
}

model BomComponent {
  id                 String          @id @default(cuid())
  bomId              String
  componentVariantId String
  quantity           Int
  bom                BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentVariant   ProductVariant  @relation("BomComponent", fields: [componentVariantId], references: [id], onDelete: Restrict)

  @@index([bomId])
  @@index([componentVariantId])
}

/// A production order: completing it consumes components and yields finished
/// units (both as immutable InventoryLedger moves), and writes a finished cost
/// layer equal to the consumed component cost.
/// A quality inspection of an incoming/produced batch (MFG-004). The result is
/// derived from the defect rate versus the acceptable quality limit (AQL).
model QualityInspection {
  id           String   @id @default(cuid())
  reference    String
  sku          String?
  sampleSize   Int
  defectsFound Int      @default(0)
  /// acceptable defect rate %, above which the batch fails
  aqlPercent   Decimal  @default(1) @db.Decimal(5, 2)
  /// PASS | FAIL
  result       String
  inspectorId  String?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([result, createdAt])
}

model WorkOrder {
  id              String          @id @default(cuid())
  workOrderNumber String          @unique
  bomId           String
  branchId        String
  quantity        Int
  /// DRAFT | COMPLETED | CANCELLED
  status          String          @default("DRAFT")
  notes           String?
  completedAt     DateTime?
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  bom             BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([bomId])
}

/// Internal knowledge-base article (KNW) — the "never leave the system" wiki.
model KnowledgeArticle {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  category          String?
  body              String
  /// DRAFT | PUBLISHED | ARCHIVED
  status            String   @default("DRAFT")
  authorAdminUserId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([category])
}

/// Internal staff announcement / alert (COM).
model Announcement {
  id                String    @id @default(cuid())
  title             String
  body              String
  /// INFO | WARNING | CRITICAL
  severity          String    @default("INFO")
  isPinned          Boolean   @default(false)
  publishedAt       DateTime?
  expiresAt         DateTime?
  authorAdminUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([publishedAt])
}

/// A stored document reference, optionally linked to an entity and e-signed (DMS).
model Document {
  id              String    @id @default(cuid())
  documentNumber  String    @unique
  name            String
  category        String?
  url             String
  entityType      String?
  entityId        String?
  /// ACTIVE | ARCHIVED
  status          String    @default("ACTIVE")
  /// NONE | PENDING | SIGNED
  signatureStatus String    @default("NONE")
  signedBy        String?
  signedAt        DateTime?
  uploadedById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([entityType, entityId])
}

/// A generic approval request any module can raise (WFL).
model ApprovalRequest {
  id            String    @id @default(cuid())
  requestNumber String    @unique
  title         String
  entityType    String?
  entityId      String?
  amount        Decimal?  @db.Decimal(14, 2)
  /// PENDING | APPROVED | REJECTED
  status        String    @default("PENDING")
  notes         String?
  requestedById String?
  decidedById   String?
  decidedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

/// A bookable resource — room, equipment or staff (CAL).
model Resource {
  id        String            @id @default(cuid())
  name      String
  /// ROOM | EQUIPMENT | STAFF
  kind      String            @default("ROOM")
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  bookings  ResourceBooking[]

  @@index([kind, isActive])
}

/// A time-bounded booking of a resource; overlaps are rejected at creation.
model ResourceBooking {
  id         String   @id @default(cuid())
  resourceId String
  title      String
  startsAt   DateTime
  endsAt     DateTime
  /// BOOKED | CANCELLED
  status     String   @default("BOOKED")
  bookedById String?
  createdAt  DateTime @default(now())
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, startsAt])
}

/// A prepaid gift card / store-credit instrument (WAL). Issuing books a cash /
/// gift-card-liability entry; redeeming recognises revenue against the liability.
model GiftCard {
  id             String                @id @default(cuid())
  code           String                @unique
  initialBalance Decimal               @db.Decimal(12, 2)
  balance        Decimal               @db.Decimal(12, 2)
  currency       String                @default("ILS")
  /// ACTIVE | DEPLETED | CANCELLED
  status         String                @default("ACTIVE")
  customerId     String?
  issuedById     String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  transactions   GiftCardTransaction[]

  @@index([status])
}

model GiftCardTransaction {
  id         String   @id @default(cuid())
  giftCardId String
  /// ISSUE | REDEEM | ADJUST
  type       String
  amount     Decimal  @db.Decimal(12, 2)
  reason     String?
  createdAt  DateTime @default(now())
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
}

/// A point-of-sale cash-register shift; closing reconciles counted vs expected.
model RegisterShift {
  id           String    @id @default(cuid())
  shiftNumber  String    @unique
  branchId     String?
  /// OPEN | CLOSED
  status       String    @default("OPEN")
  openingFloat Decimal   @db.Decimal(12, 2)
  cashSales    Decimal   @default(0) @db.Decimal(12, 2)
  countedCash  Decimal?  @db.Decimal(12, 2)
  variance     Decimal?  @db.Decimal(12, 2)
  openedById   String?
  closedById   String?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]

  @@index([status])
}

/// A recurring subscription plan (SUB).
model SubscriptionPlan {
  id            String                 @id @default(cuid())
  key           String                 @unique
  name          String
  amount        Decimal                @db.Decimal(12, 2)
  /// MONTHLY | YEARLY
  interval      String                 @default("MONTHLY")
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  subscriptions CustomerSubscription[]

  @@index([isActive])
}

/// A customer's subscription; the billing run invoices the ones that are due.
model CustomerSubscription {
  id            String           @id @default(cuid())
  planId        String
  customerId    String?
  /// ACTIVE | PAUSED | CANCELLED
  status        String           @default("ACTIVE")
  startedAt     DateTime         @default(now())
  nextBillingAt DateTime
  lastBilledAt  DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  plan          SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([status, nextBillingAt])
}

/// A pricing / discount rule applied at quote time (PRC / CPQ).
model PriceRule {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  /// PERCENT | FIXED
  type        String
  value       Decimal  @db.Decimal(12, 2)
  minQuantity Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

/// A governance / risk / compliance register item (GRC).
model ComplianceItem {
  id               String    @id @default(cuid())
  itemNumber       String    @unique
  title            String
  /// RISK | POLICY | AUDIT | TASK
  category         String?
  /// LOW | MEDIUM | HIGH | CRITICAL
  severity         String    @default("MEDIUM")
  /// OPEN | IN_PROGRESS | RESOLVED | ACCEPTED
  status           String    @default("OPEN")
  ownerAdminUserId String?
  dueAt            DateTime?
  notes            String?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([severity])
}

/// A shipping carrier with zone/weight rate cards (LOG / TMS).
model Carrier {
  id        String         @id @default(cuid())
  name      String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  rates     ShippingRate[]

  @@index([isActive])
}

/// One rate: a carrier's price for a zone up to a maximum weight.
model ShippingRate {
  id          String  @id @default(cuid())
  carrierId   String
  zone        String
  maxWeightKg Decimal @db.Decimal(8, 2)
  price       Decimal @db.Decimal(10, 2)
  carrier     Carrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  @@index([carrierId, zone])
}

/// A legal contract tracked through its lifecycle (LGL / CLM).
model Contract {
  id             String    @id @default(cuid())
  contractNumber String    @unique
  title          String
  counterparty   String
  /// VENDOR | CUSTOMER | NDA | LEASE | OTHER
  type           String?
  value          Decimal?  @db.Decimal(14, 2)
  /// DRAFT | ACTIVE | EXPIRED | TERMINATED
  status         String    @default("DRAFT")
  startsAt       DateTime? @db.Date
  endsAt         DateTime? @db.Date
  autoRenew      Boolean   @default(false)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([endsAt])
}

/// An internal IT help-desk ticket (ITSM, §4.AI).
model ITTicket {
  id                    String    @id @default(cuid())
  ticketNumber          String    @unique
  title                 String
  /// HARDWARE | SOFTWARE | ACCESS | OTHER
  category              String?
  /// LOW | MEDIUM | HIGH | URGENT
  priority              String    @default("MEDIUM")
  /// OPEN | IN_PROGRESS | RESOLVED | CLOSED
  status                String    @default("OPEN")
  requestedById         String?
  assignedToAdminUserId String?
  resolvedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
}

/// An IT asset in the company inventory (ITSM, §4.AI).
model ITAsset {
  id           String   @id @default(cuid())
  assetTag     String   @unique
  name         String
  /// LAPTOP | PHONE | MONITOR | OTHER
  category     String?
  /// IN_USE | IN_STORAGE | RETIRED
  status       String   @default("IN_USE")
  assignedTo   String?
  serialNumber String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

/// A job opening in the recruiting pipeline (HRX, §4.AG).
model JobOpening {
  id         String         @id @default(cuid())
  title      String
  department String?
  /// OPEN | ON_HOLD | CLOSED
  status     String         @default("OPEN")
  openings   Int            @default(1)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  candidates JobCandidate[]

  @@index([status])
}

/// A candidate moving through a job opening's stages (HRX).
model JobCandidate {
  id        String     @id @default(cuid())
  openingId String
  name      String
  email     String?
  /// APPLIED | SCREEN | INTERVIEW | OFFER | HIRED | REJECTED
  stage     String     @default("APPLIED")
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  opening   JobOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)

  @@index([openingId, stage])
}

/// A facilities / branch maintenance request (FAC, §4.AH).
model FacilityRequest {
  id            String    @id @default(cuid())
  requestNumber String    @unique
  branchId      String?
  title         String
  /// MAINTENANCE | CLEANING | SUPPLIES | SAFETY
  category      String?
  /// LOW | MEDIUM | HIGH
  priority      String    @default("MEDIUM")
  /// OPEN | SCHEDULED | DONE | CANCELLED
  status        String    @default("OPEN")
  scheduledAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

/// A delivery/professional-services project with budget and billing (PRJ, §4.J).
model Project {
  id           String             @id @default(cuid())
  code         String             @unique
  name         String
  /// optional link to a Customer (no hard FK — stored as id)
  customerId   String?
  /// FIXED | TIME_AND_MATERIALS | MILESTONE
  billingType  String             @default("MILESTONE")
  /// PLANNING | ACTIVE | ON_HOLD | COMPLETED | CANCELLED
  status       String             @default("PLANNING")
  budgetAmount Decimal            @default(0) @db.Decimal(14, 2)
  startDate    DateTime?          @db.Date
  endDate      DateTime?          @db.Date
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  milestones   ProjectMilestone[]
  timeEntries  ProjectTimeEntry[]

  @@index([status])
}

/// A billable milestone within a project (PRJ).
model ProjectMilestone {
  id        String    @id @default(cuid())
  projectId String
  name      String
  amount    Decimal   @default(0) @db.Decimal(14, 2)
  dueDate   DateTime? @db.Date
  /// PENDING | COMPLETED | INVOICED
  status    String    @default("PENDING")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

/// A logged time entry against a project (PRJ).
model ProjectTimeEntry {
  id          String   @id @default(cuid())
  projectId   String
  adminUserId String?
  workDate    DateTime @db.Date
  hours       Decimal  @db.Decimal(8, 2)
  ratePerHour Decimal  @default(0) @db.Decimal(10, 2)
  description String?
  billable    Boolean  @default(true)
  /// UNBILLED | INVOICED
  status      String   @default("UNBILLED")
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

/// A no-code automation: trigger → condition → actions (WFL, §4.P).
model WorkflowDefinition {
  id            String        @id @default(cuid())
  name          String
  description   String?
  /// EVENT | MANUAL | SCHEDULE
  triggerType   String        @default("MANUAL")
  triggerEvent  String?
  scheduleCron  String?
  /// rule JSON (all/any/not + {field,op,value}); null = always run
  conditionRule Json?
  /// array of {type, config} action descriptors
  actions       Json
  isActive      Boolean       @default(true)
  runCount      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  runs          WorkflowRun[]

  @@index([triggerType, isActive])
  @@index([triggerEvent])
}

/// An execution record of a workflow (WFL-004; idempotent via dedupeKey).
model WorkflowRun {
  id            String             @id @default(cuid())
  workflowId    String
  /// MATCHED | SKIPPED | FAILED
  status        String
  dedupeKey     String?            @unique
  context       Json?
  actionResults Json?
  error         String?
  createdAt     DateTime           @default(now())
  workflow      WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, createdAt])
}

/// A no-code form definition over a field schema (WFL-002).
model FormDefinition {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  /// array of field descriptors {key,label,type,required,options}
  fields      Json
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]

  @@index([isActive])
}

/// A submitted instance of a no-code form (WFL-002).
model FormSubmission {
  id            String         @id @default(cuid())
  formId        String
  data          Json
  submittedById String?
  createdAt     DateTime       @default(now())
  form          FormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, createdAt])
}

/// A custom field attached to any entity without a schema change (WFL-002).
model CustomFieldDefinition {
  id         String             @id @default(cuid())
  entityType String
  key        String
  label      String
  /// TEXT | NUMBER | BOOLEAN | DATE | SELECT
  fieldType  String             @default("TEXT")
  required   Boolean            @default(false)
  options    Json?
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  values     CustomFieldValue[]

  @@unique([entityType, key])
  @@index([entityType, isActive])
}

/// A stored value for a custom field on a specific entity row (WFL-002).
model CustomFieldValue {
  id         String                @id @default(cuid())
  fieldId    String
  entityType String
  entityId   String
  value      String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  field      CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([entityType, entityId])
}

/// A synchronous classification rule over any entity (WFL-005). When a record
/// matches the condition, the action (flag/priority/approval/escalation) applies.
model BusinessRule {
  id            String   @id @default(cuid())
  name          String
  entityType    String
  /// workflow-rules condition tree
  conditionRule Json
  /// action descriptor { type, config }
  action        Json
  priority      Int      @default(100)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([entityType, isActive])
}

/// A generic SLA target per entity type and tier, feeding escalation (WFL-005).
model SlaPolicy {
  id                String   @id @default(cuid())
  name              String
  entityType        String
  /// LOW | STANDARD | HIGH | URGENT
  tier              String   @default("STANDARD")
  responseMinutes   Int
  resolutionMinutes Int
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([entityType, tier])
  @@index([entityType, isActive])
}

/// A physical storage bin/location within a branch (WMS).
model StorageBin {
  id          String          @id @default(cuid())
  branchId    String
  code        String
  label       String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assignments BinAssignment[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
}

/// A quantity of a variant stored in a specific bin (WMS).
model BinAssignment {
  id        String     @id @default(cuid())
  binId     String
  variantId String
  quantity  Int        @default(0)
  updatedAt DateTime   @updatedAt
  bin       StorageBin @relation(fields: [binId], references: [id], onDelete: Cascade)

  @@unique([binId, variantId])
  @@index([variantId])
}

/// A tracked inventory lot/batch with optional expiry, for FEFO allocation
/// (INV-008). A parallel tracking layer over InventoryItem — quantities here
/// record lot-level detail (which batch, expiring when).
model InventoryLot {
  id         String    @id @default(cuid())
  variantId  String
  branchId   String
  lotNumber  String
  quantity   Int       @default(0)
  expiryDate DateTime? @db.Date
  receivedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([branchId, variantId, lotNumber])
  @@index([variantId, branchId])
  @@index([expiryDate])
}

/// A consolidated warehouse pick list generated from orders being prepared
/// (INV-007), with lines ordered by bin code for an efficient pick path.
model PickList {
  id          String         @id @default(cuid())
  pickNumber  String         @unique
  branchId    String?
  /// OPEN | PICKED | CANCELLED
  status      String         @default("OPEN")
  createdById String?
  lines       PickListLine[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
}

model PickListLine {
  id         String   @id @default(cuid())
  pickListId String
  variantId  String
  sku        String
  name       String
  quantity   Int
  binCode    String?
  picked     Boolean  @default(false)
  pickList   PickList @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pickListId])
}

/// A generated/received EDI document (X12) for a trading partner (IPL-003).
model EdiDocument {
  id        String   @id @default(cuid())
  /// "850" (PO) | "810" (invoice) | "856" (ASN)
  docType   String
  /// OUTBOUND | INBOUND
  direction String   @default("OUTBOUND")
  partner   String?
  reference String?
  /// GENERATED | SENT | ACKNOWLEDGED
  status    String   @default("GENERATED")
  payload   String
  createdAt DateTime @default(now())

  @@index([docType, createdAt])
}

/// A training course for employee onboarding / LMS (KNW-002).
model Course {
  id          String             @id @default(cuid())
  title       String
  description String?
  lessonCount Int                @default(1)
  /// DRAFT | PUBLISHED
  status      String             @default("DRAFT")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  enrollments CourseEnrollment[]
  quiz        CourseQuiz?

  @@index([status])
}

/// A course completion quiz (KNW-002). One quiz per course; passingScore is the
/// minimum percentage required to pass.
model CourseQuiz {
  id           String         @id @default(cuid())
  courseId     String         @unique
  passingScore Int            @default(70)
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model QuizQuestion {
  id           String     @id @default(cuid())
  quizId       String
  prompt       String
  /// array of answer option strings
  options      Json
  correctIndex Int
  sortOrder    Int        @default(0)
  quiz         CourseQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([quizId, sortOrder])
}

/// A graded attempt at a course quiz by an enrolled employee.
model QuizAttempt {
  id           String           @id @default(cuid())
  quizId       String
  enrollmentId String
  score        Int
  passed       Boolean
  quiz         CourseQuiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@index([quizId])
  @@index([enrollmentId])
}

/// An employee's enrolment + progress in a course (KNW-002).
model CourseEnrollment {
  id               String        @id @default(cuid())
  courseId         String
  employeeId       String
  completedLessons Int           @default(0)
  /// ENROLLED | IN_PROGRESS | COMPLETED
  status           String        @default("ENROLLED")
  completedAt      DateTime?
  updatedAt        DateTime      @updatedAt
  createdAt        DateTime      @default(now())
  course           Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quizAttempts     QuizAttempt[]

  @@unique([courseId, employeeId])
  @@index([employeeId])
}

/// An on-site A/B experiment with weighted variants (CMS-003).
model Experiment {
  id        String              @id @default(cuid())
  key       String              @unique
  name      String
  /// RUNNING | PAUSED | CONCLUDED
  status    String              @default("RUNNING")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  variants  ExperimentVariant[]

  @@index([status])
}

/// A variant of an experiment with impression/conversion counters (CMS-003).
model ExperimentVariant {
  id           String     @id @default(cuid())
  experimentId String
  key          String
  weight       Int        @default(50)
  impressions  Int        @default(0)
  conversions  Int        @default(0)
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([experimentId, key])
}

/// A no-code landing page composed of ordered content blocks (CMS-001).
model LandingPage {
  id        String      @id @default(cuid())
  slug      String      @unique
  title     String
  /// DRAFT | PUBLISHED
  status    String      @default("DRAFT")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  blocks    PageBlock[]

  @@index([status])
}

/// One content block within a landing page (CMS-001).
model PageBlock {
  id        String      @id @default(cuid())
  pageId    String
  /// HERO | TEXT | IMAGE | CTA
  type      String      @default("TEXT")
  heading   String?
  body      String?
  imageUrl  String?
  linkUrl   String?
  sortOrder Int         @default(0)
  page      LandingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, sortOrder])
}

/// A merchandising banner shown in a storefront placement (CMS-003).
model Banner {
  id        String    @id @default(cuid())
  title     String
  /// HOME_HERO | HOME_STRIP | CATEGORY_TOP | CHECKOUT
  placement String    @default("HOME_HERO")
  imageUrl  String?
  linkUrl   String?
  priority  Int       @default(100)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([placement, isActive])
}

/// An automatic cart-level promotion evaluated at checkout (CMS-002).
model Promotion {
  id           String    @id @default(cuid())
  name         String
  /// PERCENT | FIXED | FREE_SHIPPING | BOGO
  type         String    @default("PERCENT")
  value        Decimal   @default(0) @db.Decimal(10, 2)
  /// scope the discount to one category (null = whole cart)
  categoryId   String?
  /// BOGO: buy this many...
  buyQuantity  Int       @default(0)
  /// ...get this many at no charge (cheapest units)
  getQuantity  Int       @default(0)
  minCartTotal Decimal   @default(0) @db.Decimal(10, 2)
  minQuantity  Int       @default(0)
  priority     Int       @default(100)
  stackable    Boolean   @default(false)
  isActive     Boolean   @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive])
}

/// A named B2B price list with per-variant negotiated prices (POR-003).
model PriceList {
  id        String          @id @default(cuid())
  name      String
  currency  String          @default("ILS")
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     PriceListItem[]
  accounts  B2bAccount[]

  @@index([isActive])
}

/// A per-variant price within a price list (POR-003).
model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  variantId   String
  price       Decimal   @db.Decimal(10, 2)
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([priceListId, variantId])
  @@index([variantId])
}

/// A B2B trade account: negotiated discount, credit limit and terms (POR-003).
model B2bAccount {
  id               String               @id @default(cuid())
  customerId       String               @unique
  companyName      String?
  taxId            String?
  priceListId      String?
  discountPercent  Decimal              @default(0) @db.Decimal(5, 2)
  creditLimit      Decimal              @default(0) @db.Decimal(14, 2)
  paymentTermsDays Int                  @default(30)
  priceList        PriceList?           @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  /// ACTIVE | SUSPENDED
  status           String               @default("ACTIVE")
  buyers           B2bAuthorizedBuyer[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([status])
  @@index([priceListId])
}

/// An authorized purchaser acting on behalf of a B2bAccount (POR-003). Each
/// buyer may carry a per-order spend limit (0 = unlimited) and can be suspended
/// independently of the account.
model B2bAuthorizedBuyer {
  id         String     @id @default(cuid())
  accountId  String
  name       String
  email      String
  /// free-text role, e.g. רוכש / מאשר
  role       String?
  /// per-order spend limit in ₪; 0 = unlimited
  spendLimit Decimal    @default(0) @db.Decimal(14, 2)
  /// ACTIVE | SUSPENDED
  status     String     @default("ACTIVE")
  account    B2bAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([accountId, email])
  @@index([accountId, status])
}

/// A digital-marketing campaign with budget/spend/revenue for ROAS (DMK, §4.R).
model MarketingCampaign {
  id        String    @id @default(cuid())
  name      String
  /// GOOGLE_ADS | META | TIKTOK | EMAIL | ORGANIC | OTHER
  channel   String    @default("OTHER")
  /// PLANNED | ACTIVE | PAUSED | COMPLETED
  status    String    @default("ACTIVE")
  budget    Decimal   @default(0) @db.Decimal(14, 2)
  spend     Decimal   @default(0) @db.Decimal(14, 2)
  revenue   Decimal   @default(0) @db.Decimal(14, 2)
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
}

/// An affiliate/referral partner earning commission (DMK-005).
model AffiliatePartner {
  id                String     @id @default(cuid())
  name              String
  code              String     @unique
  commissionPercent Decimal    @default(0) @db.Decimal(5, 2)
  /// ACTIVE | SUSPENDED
  status            String     @default("ACTIVE")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  referrals         Referral[]

  @@index([status])
}

/// A referred sale and its commission, payable through AP (DMK-005).
model Referral {
  id         String           @id @default(cuid())
  partnerId  String
  orderId    String?
  amount     Decimal          @db.Decimal(14, 2)
  commission Decimal          @db.Decimal(14, 2)
  /// PENDING | APPROVED | PAID
  status     String           @default("PENDING")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  partner    AffiliatePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, status])
}

/// Israeli withholding-tax (ניכוי מס במקור) rate per category, effective-dated.
/// Rates are examples — verify with an accountant before use (FIN-TAX / IL).
model WithholdingTaxRule {
  id            String   @id @default(cuid())
  category      String
  /// percentage, e.g. 30.00
  ratePercent   Decimal  @db.Decimal(5, 2)
  effectiveFrom DateTime @db.Date
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category, isActive])
}

/// A saved report over a curated dataset + the semantic layer (RPT, §4.Q).
model ReportDefinition {
  id          String           @id @default(cuid())
  name        String
  description String?
  datasetKey  String
  /// chosen dimension keys (string[])
  dimensions  Json
  /// chosen measure keys (string[])
  measures    Json
  /// optional filter rule tree (workflow-rules format)
  filter      Json?
  /// { by, dir } sort spec
  sort        Json?
  isActive    Boolean          @default(true)
  lastRunAt   DateTime?
  schedules   ReportSchedule[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([datasetKey])
}

/// A recurring schedule that runs a saved report and captures a CSV snapshot
/// (RPT-003, scheduled reports). Processed by the report-schedules cron.
model ReportSchedule {
  id         String           @id @default(cuid())
  reportId   String
  /// DAILY | WEEKLY | MONTHLY
  frequency  String           @default("WEEKLY")
  /// comma/newline-separated recipient emails for delivery (optional)
  recipients String?
  isActive   Boolean          @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime
  report     ReportDefinition @relation(fields: [reportId], references: [id], onDelete: Cascade)
  runs       ReportRun[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([isActive, nextRunAt])
  @@index([reportId])
}

/// A captured snapshot from a scheduled report run.
model ReportRun {
  id         String         @id @default(cuid())
  scheduleId String
  reportName String
  rowCount   Int
  csv        String
  schedule   ReportSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@index([scheduleId, createdAt])
}

/// A legal entity (company) for multi-entity accounting + consolidation (ENT, §4.AD).
model LegalEntity {
  id                 String                    @id @default(cuid())
  code               String                    @unique
  name               String
  functionalCurrency String                    @default("ILS")
  /// rate to convert this entity's functional currency into the base currency
  fxRateToBase       Decimal                   @default(1) @db.Decimal(18, 6)
  isBase             Boolean                   @default(false)
  isActive           Boolean                   @default(true)
  parentId           String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  parent             LegalEntity?              @relation("EntityHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children           LegalEntity[]             @relation("EntityHierarchy")
  journalEntries     JournalEntry[]
  intercompanyFrom   IntercompanyTransaction[] @relation("IntercompanyFrom")
  intercompanyTo     IntercompanyTransaction[] @relation("IntercompanyTo")

  @@index([isActive])
}

/// A transaction between two legal entities, eliminated on consolidation (ENT-002).
model IntercompanyTransaction {
  id                String      @id @default(cuid())
  transactionNumber String      @unique
  fromEntityId      String
  toEntityId        String
  amount            Decimal     @db.Decimal(14, 2)
  currency          String      @default("ILS")
  description       String?
  occurredAt        DateTime    @db.Date
  /// OPEN | ELIMINATED
  status            String      @default("OPEN")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  fromEntity        LegalEntity @relation("IntercompanyFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity          LegalEntity @relation("IntercompanyTo", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@index([status])
}

/// An issued API key for the internal API platform (IPL-002). Only the hash is
/// stored; the plaintext is shown once at issue time.
model ApiKey {
  id              String          @id @default(cuid())
  name            String
  prefix          String          @unique
  hashedKey       String
  /// string[] of granted scopes
  scopes          Json
  rateLimitPerMin Int             @default(120)
  isActive        Boolean         @default(true)
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  requestLogs     ApiRequestLog[]

  @@index([isActive])
}

/// A logged API request for usage/rate visibility (IPL-002).
model ApiRequestLog {
  id         String   @id @default(cuid())
  apiKeyId   String?
  method     String
  path       String
  status     Int
  durationMs Int      @default(0)
  createdAt  DateTime @default(now())
  apiKey     ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([apiKeyId, createdAt])
}

/// A registered outbound webhook endpoint (IPL-001).
model WebhookEndpoint {
  id         String            @id @default(cuid())
  name       String
  url        String
  secret     String
  /// string[] of subscribed event names
  events     Json
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]

  @@index([isActive])
}

/// One delivery attempt record for an outbound webhook (IPL-001; idempotent).
model WebhookDelivery {
  id             String          @id @default(cuid())
  endpointId     String
  event          String
  payload        Json
  /// PENDING | SENT | FAILED
  status         String          @default("PENDING")
  dedupeKey      String?         @unique
  attempts       Int             @default(0)
  responseStatus Int?
  error          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  endpoint       WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([endpointId, createdAt])
}

model Customer {
  id                        String                      @id @default(cuid())
  userId                    String?                     @unique
  email                     String?                     @unique
  phone                     String?
  firstName                 String?
  lastName                  String?
  user                      User?                       @relation(fields: [userId], references: [id])
  carts                     Cart[]
  orders                    Order[]
  addresses                 CustomerAddress[]
  wishlist                  Wishlist?
  savedSizes                SavedSize[]
  appointments              Appointment[]
  otpChallenges             OtpChallenge[]
  giftProfiles              GiftProfile[]
  styleProfile              StyleProfile?
  recommendationSessions    RecommendationSession[]
  aiRuns                    AiRun[]
  pushSubscriptions         PushSubscription[]
  tryOnSessions             TryOnSession[]
  feedback                  UserFeedback[]
  analyticsVisitors         AnalyticsVisitor[]
  analyticsSessions         AnalyticsSession[]
  analyticsEvents           AnalyticsEvent[]
  attributionTouchpoints    AttributionTouchpoint[]
  metricSnapshots           CustomerMetricSnapshot[]
  notes                     CustomerNote[]
  tasks                     CustomerTask[]
  segmentMemberships        CustomerSegmentMembership[]
  campaignAudienceSnapshots CampaignAudienceSnapshot[]
  invoices                  CustomerInvoice[]
  receipts                  CustomerReceipt[]
  journeyEnrollments        JourneyEnrollment[]
  consentRecords            ConsentRecord[]
  loyaltyAccount            LoyaltyAccount?
  serviceRequests           ServiceRequest[]
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
}

/// A customer's loyalty membership: redeemable points balance, lifetime points
/// (which drive the tier), and the resolved tier (CRM-LOY).
model LoyaltyAccount {
  id             String               @id @default(cuid())
  customerId     String               @unique
  pointsBalance  Int                  @default(0)
  lifetimePoints Int                  @default(0)
  tier           String               @default("BRONZE")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  customer       Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions   LoyaltyTransaction[]

  @@index([tier])
}

/// One points movement (EARN / REDEEM / ADJUST); append-only ledger of points.
model LoyaltyTransaction {
  id               String         @id @default(cuid())
  loyaltyAccountId String
  /// EARN | REDEEM | ADJUST
  type             String
  points           Int
  reason           String?
  orderId          String?
  createdAt        DateTime       @default(now())
  account          LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)

  @@index([loyaltyAccountId])
  @@index([orderId])
}

/// Append-only marketing-consent log. Current consent per channel is the latest
/// record for that channel; history is preserved for compliance.
model ConsentRecord {
  id         String   @id @default(cuid())
  customerId String
  /// EMAIL | SMS | PUSH | WHATSAPP
  channel    String
  /// GRANTED | REVOKED
  status     String
  source     String?
  note       String?
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, channel, createdAt])
}

model OtpChallenge {
  id         String     @id @default(cuid())
  customerId String?
  identifier String
  channel    OtpChannel
  codeHash   String
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  createdAt  DateTime   @default(now())

  @@index([identifier, channel])
}

model NewsletterSubscription {
  id          String    @id @default(cuid())
  email       String    @unique
  status      String    @default("SUBSCRIBED")
  source      String?
  consentedAt DateTime?
  consentText String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OfflineActionReceipt {
  id          String    @id @default(cuid())
  deviceId    String
  actionId    String
  kind        String
  status      String    @default("PROCESSING")
  result      Json?
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([deviceId, actionId])
  @@index([kind, status])
  @@index([createdAt])
}

model PushSubscription {
  id                 String                @id @default(cuid())
  endpoint           String                @unique
  deviceId           String?
  customerId         String?
  sessionKey         String?
  p256dh             String
  auth               String
  userAgent          String?
  status             String                @default("ACTIVE")
  marketingOptIn     Boolean               @default(false)
  transactionalOptIn Boolean               @default(true)
  lastSeenAt         DateTime              @default(now())
  revokedAt          DateTime?
  customer           Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deliveries         PushDelivery[]
  interests          ProductPushInterest[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([deviceId])
  @@index([customerId])
  @@index([sessionKey])
  @@index([status, marketingOptIn])
}

model PushCampaign {
  id          String         @id @default(cuid())
  title       String
  body        String
  targetUrl   String
  segment     String         @default("MARKETING_OPT_IN")
  status      String         @default("DRAFT")
  scheduledAt DateTime?
  sentAt      DateTime?
  lastError   String?
  deliveries  PushDelivery[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, scheduledAt])
}

model PushDelivery {
  id             String           @id @default(cuid())
  campaignId     String?
  subscriptionId String
  endpoint       String
  status         String           @default("PENDING")
  error          String?
  deliveredAt    DateTime?
  campaign       PushCampaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([campaignId])
  @@index([subscriptionId, status])
  @@index([status, createdAt])
}

model ProductPushInterest {
  id             String           @id @default(cuid())
  productId      String
  subscriptionId String
  kind           String           @default("BACK_IN_STOCK")
  status         String           @default("ACTIVE")
  notifiedAt     DateTime?
  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([productId, subscriptionId, kind])
  @@index([status, kind])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  recipient  String
  phone      String
  city       String
  street     String
  postalCode String?
  isDefault  Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model SavedSize {
  id         String   @id @default(cuid())
  customerId String
  kind       String
  value      String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, kind])
}

model Wishlist {
  id         String         @id @default(cuid())
  customerId String         @unique
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]
  updatedAt  DateTime       @updatedAt
}

model WishlistItem {
  id          String         @id @default(cuid())
  wishlistId  String
  variantId   String
  wishlist    Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  /// I-05: price at the moment this item was saved, so a real "price changed
  /// since you saved it" cue can be shown. Null for items saved before this
  /// column existed -- never backfilled with a guessed value.
  priceAtSave Decimal?       @db.Decimal(10, 2)

  @@unique([wishlistId, variantId])
}

model Cart {
  id            String     @id @default(cuid())
  customerId    String?
  sessionKey    String?
  status        CartStatus @default(ACTIVE)
  currency      String     @default("ILS")
  couponCode    String?
  giftWrap      Boolean    @default(false)
  giftMessage   String?
  expiresAt     DateTime?
  mergeMetadata Json?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  items         CartItem[]
  orders        Order[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([sessionKey, status])
  @@index([customerId, status])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  variantId String
  branchId  String?
  quantity  Int            @default(1)
  unitPrice Decimal        @db.Decimal(10, 2)
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId, branchId])
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  percentOff  Int?
  amountOff   Decimal?  @db.Decimal(10, 2)
  startsAt    DateTime
  endsAt      DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
}

model Order {
  id                     String                  @id @default(cuid())
  orderNumber            String                  @unique
  cartId                 String?
  customerId             String?
  branchId               String?
  registerShiftId        String?
  status                 OrderStatus             @default(PENDING_PAYMENT)
  financialTreatment     FinancialTreatment      @default(UNKNOWN_BLOCKED)
  fulfillmentMethod      FulfillmentMethod       @default(DELIVERY)
  currency               String                  @default("ILS")
  subtotal               Decimal                 @db.Decimal(10, 2)
  discountTotal          Decimal                 @default(0) @db.Decimal(10, 2)
  shippingTotal          Decimal                 @default(0) @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  email                  String
  phone                  String
  recipientName          String
  shippingAddress        Json?
  paidAt                 DateTime?
  preparingAt            DateTime?
  readyForPickupAt       DateTime?
  shippedAt              DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  refundedAt             DateTime?
  cart                   Cart?                   @relation(fields: [cartId], references: [id])
  customer               Customer?               @relation(fields: [customerId], references: [id])
  branch                 Branch?                 @relation(fields: [branchId], references: [id])
  registerShift          RegisterShift?          @relation(fields: [registerShiftId], references: [id])
  items                  OrderItem[]
  payments               Payment[]
  shipments              Shipment[]
  returns                ReturnRequest[]
  analyticsEvents        AnalyticsEvent[]
  attributionTouchpoints AttributionTouchpoint[]
  orderAttribution       OrderAttribution?
  financeLedgerEntries   FinanceLedgerEntry[]
  customerInvoices       CustomerInvoice[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([registerShiftId])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  variantId String
  name      String
  sku       String
  quantity  Int
  unitPrice Decimal        @db.Decimal(10, 2)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerPaymentId String?
  status            PaymentStatus @default(PENDING)
  providerStatus    String?
