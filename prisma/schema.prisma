generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductAvailabilityMode {
  READY_TO_ORDER
  MADE_TO_ORDER
  CONSULTATION
}

enum ProductSource {
  OWN
  DROPSHIP_SHOPIFY
}

enum MediaKind {
  IMAGE
  VIDEO
  TRY_ON_REFERENCE
}

enum ProductMediaRole {
  PRIMARY
  ALTERNATE
  SCALE
  CONSTRUCTION
  MATERIAL
  CONTEXT
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  READY_FOR_PICKUP
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum FulfillmentMethod {
  DELIVERY
  PICKUP
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OtpChannel {
  EMAIL
  SMS
}

enum BranchKind {
  ONLINE
  PHYSICAL
}

enum ServiceRequestStatus {
  NEW
  IN_REVIEW
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
}

enum ServiceContactPreference {
  EMAIL
  PHONE
  WHATSAPP
  ANY
}

enum AdminPermission {
  SYSTEM
  BLOG
  BLOG_READ
  BLOG_WRITE
  CATALOG
  CATALOG_READ
  CATALOG_WRITE
  INVENTORY
  INVENTORY_READ
  INVENTORY_WRITE
  ORDERS
  ORDERS_READ
  ORDERS_WRITE
  ORDERS_REFUND
  CUSTOMER_SERVICE
  CUSTOMER_VIEW
  CUSTOMER_WRITE
  ANALYTICS_READ
  CRM_READ
  CRM_WRITE
  ERP_READ
  ERP_WRITE
  FINANCE_READ
  SYSTEM_CONFIG
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum OutboxEventStatus {
  PENDING
  PUBLISHED
  PROCESSING
  PROCESSED
  FAILED
}

enum JobRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  customer      Customer?
  adminUser     AdminUser?
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Collection {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  description  String?
  heroImageUrl String?
  isFeatured   Boolean   @default(false)
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Material {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  products Product[]
}

model Stone {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  products Product[]
}

model Product {
  id                     String                   @id @default(cuid())
  slug                   String                   @unique
  sku                    String                   @unique
  name                   String
  shortDescription       String
  description            String
  status                 ProductStatus            @default(DRAFT)
  categoryId             String
  materialId             String
  stoneId                String?
  basePrice              Decimal                  @db.Decimal(10, 2)
  availabilityMode       ProductAvailabilityMode  @default(READY_TO_ORDER)
  source                 ProductSource            @default(OWN)
  externalProvider       String?
  externalProductId      String?
  externalHandle         String?
  supplierKey            String?
  externalSyncedAt       DateTime?
  commerceHighlights     String[]                 @default([])
  deliveryPromise        String?
  returnPolicy           String?
  careInstructions       String?
  warranty               String?
  countryOfManufacture   String?
  manufacturerOrImporter String?
  materialDetails        String?
  measurements           String?
  stoneDetails           String?
  factSourceReference    String?
  factVerifiedAt         DateTime?
  factVerifiedBy         String?
  policySourceReference  String?
  policyVerifiedAt       DateTime?
  policyVerifiedBy       String?
  tags                   String[]
  category               Category                 @relation(fields: [categoryId], references: [id])
  material               Material                 @relation(fields: [materialId], references: [id])
  stone                  Stone?                   @relation(fields: [stoneId], references: [id])
  collections            Collection[]
  variants               ProductVariant[]
  media                  ProductMedia[]
  searchEmbeddings       ProductSearchEmbedding[]
  pushInterests          ProductPushInterest[]
  blogPosts              BlogPost[]
  searchEvents           SearchEvent[]
  viewEvents             ProductViewEvent[]
  clickEvents            ProductClickEvent[]
  analyticsEvents        AnalyticsEvent[]
  dailyMetrics           ProductDailyMetric[]
  purchaseOrderItems     PurchaseOrderItem[]
  costSnapshots          ProductCostSnapshot[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([status])
  @@index([source])
  @@index([externalProvider, externalProductId])
  @@index([supplierKey])
  @@index([categoryId])
  @@index([materialId])
}

model ProductSearchEmbedding {
  id         String   @id @default(cuid())
  productId  String
  model      String
  dimension  Int
  sourceHash String
  vector     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, model, dimension])
  @@index([model, dimension])
  @@index([sourceHash])
}

model ProductVariant {
  id                 String                @id @default(cuid())
  productId          String
  sku                String                @unique
  name               String
  size               String?
  metalColor         String?
  stoneColor         String?
  priceDelta         Decimal               @default(0) @db.Decimal(10, 2)
  isDefault          Boolean               @default(false)
  externalVariantId  String?
  product            Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices             Price[]
  inventoryItems     InventoryItem[]
  inventoryLedgers   InventoryLedger[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceipts      GoodsReceipt[]
  costSnapshots      ProductCostSnapshot[]
  wishlistItems      WishlistItem[]
  tryOnSessions      TryOnSession[]

  @@index([productId])
  @@index([externalVariantId])
}

model Price {
  id        String         @id @default(cuid())
  variantId String
  currency  String         @default("ILS")
  amount    Decimal        @db.Decimal(10, 2)
  compareAt Decimal?       @db.Decimal(10, 2)
  validFrom DateTime       @default(now())
  validTo   DateTime?
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, validFrom])
}

model ProductMedia {
  id           String            @id @default(cuid())
  productId    String
  kind         MediaKind         @default(IMAGE)
  role         ProductMediaRole?
  url          String
  alt          String
  cloudinaryId String?
  width        Int?
  height       Int?
  isPrimary    Boolean           @default(false)
  sortOrder    Int               @default(0)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([productId, role])
}

model Branch {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  address          String
  city             String
  phone            String
  whatsapp         String?
  latitude         Float?
  longitude        Float?
  openingHours     Json
  services         String[]
  kind             BranchKind        @default(PHYSICAL)
  isApproved       Boolean           @default(false)
  isPublic         Boolean           @default(false)
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  inventoryItems   InventoryItem[]
  inventoryLedgers InventoryLedger[]
  appointments     Appointment[]
  orders           Order[]
  goodsReceipts    GoodsReceipt[]

  @@index([kind, isApproved, isPublic, isActive, sortOrder])
}

model ServiceSettings {
  id                      String   @id @default("default")
  phoneE164               String   @default("+972000000000")
  displayPhone            String   @default("05X-XXXXXXX")
  serviceEmail            String   @default("support@example.com")
  physicalBranchesEnabled Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model ContactTopic {
  id             String           @id @default(cuid())
  slug           String           @unique
  label          String
  description    String?
  recipientEmail String?
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  requests       ServiceRequest[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([isActive, sortOrder])
}

model ServiceRequest {
  id                   String                     @id @default(cuid())
  topicId              String?
  topic                ContactTopic?              @relation(fields: [topicId], references: [id], onDelete: SetNull)
  status               ServiceRequestStatus       @default(NEW)
  name                 String
  phone                String
  email                String
  orderNumber          String?
  productReference     String?
  preferredContact     ServiceContactPreference   @default(ANY)
  preferredContactTime String?
  message              String
  adminNotes           String?
  attachments          ServiceRequestAttachment[]
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([status, createdAt])
  @@index([topicId])
  @@index([email])
  @@index([phone])
}

model ServiceRequestAttachment {
  id               String         @id @default(cuid())
  serviceRequestId String
  provider         String
  publicId         String
  secureUrl        String
  originalFilename String
  contentType      String
  bytes            Int
  width            Int?
  height           Int?
  request          ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@index([serviceRequestId])
}

model InventoryItem {
  id          String         @id @default(cuid())
  branchId    String
  variantId   String
  quantity    Int            @default(0)
  reserved    Int            @default(0)
  safetyStock Int            @default(0)
  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  updatedAt   DateTime       @updatedAt

  @@unique([branchId, variantId])
  @@index([variantId])
}

model InventoryReservation {
  id         String    @id @default(cuid())
  branchId   String
  variantId  String
  quantity   Int
  cartId     String?
  orderId    String?
  expiresAt  DateTime
  releasedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([branchId, variantId])
  @@index([cartId])
  @@index([orderId])
}

model InventoryLedger {
  id        String         @id @default(cuid())
  branchId  String
  variantId String
  delta     Int
  reason    String
  reference String?
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([branchId, variantId])
  @@index([createdAt])
}

model Customer {
  id                        String                      @id @default(cuid())
  userId                    String?                     @unique
  email                     String?                     @unique
  phone                     String?
  firstName                 String?
  lastName                  String?
  user                      User?                       @relation(fields: [userId], references: [id])
  carts                     Cart[]
  orders                    Order[]
  addresses                 CustomerAddress[]
  wishlist                  Wishlist?
  savedSizes                SavedSize[]
  appointments              Appointment[]
  otpChallenges             OtpChallenge[]
  giftProfiles              GiftProfile[]
  styleProfile              StyleProfile?
  recommendationSessions    RecommendationSession[]
  aiRuns                    AiRun[]
  pushSubscriptions         PushSubscription[]
  tryOnSessions             TryOnSession[]
  feedback                  UserFeedback[]
  analyticsVisitors         AnalyticsVisitor[]
  analyticsSessions         AnalyticsSession[]
  analyticsEvents           AnalyticsEvent[]
  attributionTouchpoints    AttributionTouchpoint[]
  metricSnapshots           CustomerMetricSnapshot[]
  notes                     CustomerNote[]
  tasks                     CustomerTask[]
  segmentMemberships        CustomerSegmentMembership[]
  campaignAudienceSnapshots CampaignAudienceSnapshot[]
  invoices                  CustomerInvoice[]
  receipts                  CustomerReceipt[]
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
}

model OtpChallenge {
  id         String     @id @default(cuid())
  customerId String?
  identifier String
  channel    OtpChannel
  codeHash   String
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  createdAt  DateTime   @default(now())

  @@index([identifier, channel])
}

model NewsletterSubscription {
  id          String    @id @default(cuid())
  email       String    @unique
  status      String    @default("SUBSCRIBED")
  source      String?
  consentedAt DateTime?
  consentText String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OfflineActionReceipt {
  id          String    @id @default(cuid())
  deviceId    String
  actionId    String
  kind        String
  status      String    @default("PROCESSING")
  result      Json?
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([deviceId, actionId])
  @@index([kind, status])
  @@index([createdAt])
}

model PushSubscription {
  id                 String                @id @default(cuid())
  endpoint           String                @unique
  deviceId           String?
  customerId         String?
  sessionKey         String?
  p256dh             String
  auth               String
  userAgent          String?
  status             String                @default("ACTIVE")
  marketingOptIn     Boolean               @default(false)
  transactionalOptIn Boolean               @default(true)
  lastSeenAt         DateTime              @default(now())
  revokedAt          DateTime?
  customer           Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deliveries         PushDelivery[]
  interests          ProductPushInterest[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([deviceId])
  @@index([customerId])
  @@index([sessionKey])
  @@index([status, marketingOptIn])
}

model PushCampaign {
  id          String         @id @default(cuid())
  title       String
  body        String
  targetUrl   String
  segment     String         @default("MARKETING_OPT_IN")
  status      String         @default("DRAFT")
  scheduledAt DateTime?
  sentAt      DateTime?
  lastError   String?
  deliveries  PushDelivery[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, scheduledAt])
}

model PushDelivery {
  id             String           @id @default(cuid())
  campaignId     String?
  subscriptionId String
  endpoint       String
  status         String           @default("PENDING")
  error          String?
  deliveredAt    DateTime?
  campaign       PushCampaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([campaignId])
  @@index([subscriptionId, status])
  @@index([status, createdAt])
}

model ProductPushInterest {
  id             String           @id @default(cuid())
  productId      String
  subscriptionId String
  kind           String           @default("BACK_IN_STOCK")
  status         String           @default("ACTIVE")
  notifiedAt     DateTime?
  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([productId, subscriptionId, kind])
  @@index([status, kind])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  recipient  String
  phone      String
  city       String
  street     String
  postalCode String?
  isDefault  Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model SavedSize {
  id         String   @id @default(cuid())
  customerId String
  kind       String
  value      String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, kind])
}

model Wishlist {
  id         String         @id @default(cuid())
  customerId String         @unique
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]
  updatedAt  DateTime       @updatedAt
}

model WishlistItem {
  id         String         @id @default(cuid())
  wishlistId String
  variantId  String
  wishlist   Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([wishlistId, variantId])
}

model Cart {
  id            String     @id @default(cuid())
  customerId    String?
  sessionKey    String?
  status        CartStatus @default(ACTIVE)
  currency      String     @default("ILS")
  couponCode    String?
  giftWrap      Boolean    @default(false)
  giftMessage   String?
  expiresAt     DateTime?
  mergeMetadata Json?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  items         CartItem[]
  orders        Order[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([sessionKey, status])
  @@index([customerId, status])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  variantId String
  branchId  String?
  quantity  Int            @default(1)
  unitPrice Decimal        @db.Decimal(10, 2)
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId, branchId])
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  percentOff  Int?
  amountOff   Decimal?  @db.Decimal(10, 2)
  startsAt    DateTime
  endsAt      DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
}

model Order {
  id                     String                  @id @default(cuid())
  orderNumber            String                  @unique
  cartId                 String?
  customerId             String?
  branchId               String?
  status                 OrderStatus             @default(PENDING_PAYMENT)
  fulfillmentMethod      FulfillmentMethod       @default(DELIVERY)
  currency               String                  @default("ILS")
  subtotal               Decimal                 @db.Decimal(10, 2)
  discountTotal          Decimal                 @default(0) @db.Decimal(10, 2)
  shippingTotal          Decimal                 @default(0) @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  email                  String
  phone                  String
  recipientName          String
  shippingAddress        Json?
  paidAt                 DateTime?
  preparingAt            DateTime?
  readyForPickupAt       DateTime?
  shippedAt              DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  refundedAt             DateTime?
  cart                   Cart?                   @relation(fields: [cartId], references: [id])
  customer               Customer?               @relation(fields: [customerId], references: [id])
  branch                 Branch?                 @relation(fields: [branchId], references: [id])
  items                  OrderItem[]
  payments               Payment[]
  shipments              Shipment[]
  returns                ReturnRequest[]
  analyticsEvents        AnalyticsEvent[]
  attributionTouchpoints AttributionTouchpoint[]
  orderAttribution       OrderAttribution?
  financeLedgerEntries   FinanceLedgerEntry[]
  customerInvoices       CustomerInvoice[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  variantId String
  name      String
  sku       String
  quantity  Int
  unitPrice Decimal        @db.Decimal(10, 2)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerPaymentId String?
  status            PaymentStatus @default(PENDING)
  providerStatus    String?
  failureCode       String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("ILS")
  idempotencyKey    String        @unique
  rawPayload        Json?
  capturedAt        DateTime?
  refundedAt        DateTime?
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ShopifyOrderMirror {
  id                String    @id @default(cuid())
  shopifyOrderId    String    @unique
  shopifyOrderName  String?
  customerEmail     String?
  financialStatus   String?
  fulfillmentStatus String?
  currency          String    @default("ILS")
  total             Decimal   @default(0) @db.Decimal(10, 2)
  supplierKey       String?
  lineItems         Json
  rawPayload        Json?
  processedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerEmail])
  @@index([financialStatus])
  @@index([fulfillmentStatus])
  @@index([supplierKey])
}

model Shipment {
  id          String    @id @default(cuid())
  orderId     String
  provider    String?
  tracking    String?
  status      String
  shippedAt   DateTime?
  deliveredAt DateTime?
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ReturnRequest {
  id        String   @id @default(cuid())
  orderId   String
  reason    String
  status    String
  notes     String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Appointment {
  id         String            @id @default(cuid())
  branchId   String
  customerId String?
  topic      String
  name       String
  email      String?
  phone      String
  startsAt   DateTime
  status     AppointmentStatus @default(REQUESTED)
  notes      String?
  branch     Branch            @relation(fields: [branchId], references: [id])
  customer   Customer?         @relation(fields: [customerId], references: [id])
  createdAt  DateTime          @default(now())
}

model GiftProfile {
  id         String    @id @default(cuid())
  customerId String?
  relation   String
  occasion   String
  budgetMin  Int?
  budgetMax  Int?
  style      String[]
  notes      String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdAt  DateTime  @default(now())
}

model StyleProfile {
  id          String   @id @default(cuid())
  customerId  String   @unique
  metalColors String[]
  styles      String[]
  ringSize    String?
  necklaceFit String?
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
}

model RecommendationSession {
  id         String    @id @default(cuid())
  customerId String?
  input      Json
  output     Json
  model      String
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdAt  DateTime  @default(now())
}

model AiRun {
  id            String       @id @default(cuid())
  customerId    String?
  kind          String
  status        String       @default("STARTED")
  model         String
  promptVersion String
  input         Json
  output        Json?
  error         String?
  metadata      Json?
