  vendorPayment   VendorPayment @relation(fields: [vendorPaymentId], references: [id], onDelete: Cascade)
  vendorInvoice   VendorInvoice @relation(fields: [vendorInvoiceId], references: [id], onDelete: Restrict)

  @@index([vendorPaymentId])
  @@index([vendorInvoiceId])
}

/// Accounts Receivable: a customer invoice document, optionally from an order.
model CustomerInvoice {
  id            String                      @id @default(cuid())
  invoiceNumber String                      @unique
  customerId    String?
  orderId       String?
  /// DRAFT | ISSUED | PARTIALLY_PAID | PAID | CANCELLED
  status        String                      @default("DRAFT")
  currency      String                      @default("ILS")
  subtotal      Decimal                     @default(0) @db.Decimal(14, 2)
  taxTotal      Decimal                     @default(0) @db.Decimal(14, 2)
  total         Decimal                     @default(0) @db.Decimal(14, 2)
  paidTotal     Decimal                     @default(0) @db.Decimal(14, 2)
  invoiceDate   DateTime                    @db.Date
  dueDate       DateTime?                   @db.Date
  issuedAt      DateTime?
  notes         String?
  metadata      Json?
  customer      Customer?                   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order         Order?                      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  lines         CustomerInvoiceLine[]
  allocations   CustomerReceiptAllocation[]
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([status, dueDate])
  @@index([customerId])
  @@index([orderId])
}

model CustomerInvoiceLine {
  id                String          @id @default(cuid())
  customerInvoiceId String
  orderItemId       String?
  description       String
  quantity          Int
  unitPrice         Decimal         @db.Decimal(14, 2)
  lineTotal         Decimal         @db.Decimal(14, 2)
  customerInvoice   CustomerInvoice @relation(fields: [customerInvoiceId], references: [id], onDelete: Cascade)

  @@index([customerInvoiceId])
}

model CustomerReceipt {
  id          String                      @id @default(cuid())
  customerId  String?
  amount      Decimal                     @db.Decimal(14, 2)
  currency    String                      @default("ILS")
  method      String                      @default("card")
  reference   String?
  receivedAt  DateTime                    @default(now())
  notes       String?
  customer    Customer?                   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  allocations CustomerReceiptAllocation[]
  createdAt   DateTime                    @default(now())

  @@index([customerId, receivedAt])
}

/// Allocation of a customer receipt to a specific invoice (supports split receipts).
model CustomerReceiptAllocation {
  id                String          @id @default(cuid())
  customerReceiptId String
  customerInvoiceId String
  amount            Decimal         @db.Decimal(14, 2)
  customerReceipt   CustomerReceipt @relation(fields: [customerReceiptId], references: [id], onDelete: Cascade)
  customerInvoice   CustomerInvoice @relation(fields: [customerInvoiceId], references: [id], onDelete: Restrict)

  @@index([customerReceiptId])
  @@index([customerInvoiceId])
}

/// Immutable cost layer per goods receipt, for FIFO / weighted-average
/// inventory valuation (INV-002). Append-only; never mutated.
model ItemCostLayer {
  id         String   @id @default(cuid())
  branchId   String
  variantId  String
  unitCost   Decimal  @db.Decimal(14, 2)
  quantity   Int
  sourceType String   @default("purchase_receipt")
  sourceId   String?
  currency   String   @default("ILS")
  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([branchId, variantId, receivedAt])
  @@index([variantId])
}

model FinanceLedgerEntry {
  id              String         @id @default(cuid())
  entryDate       DateTime       @db.Date
  type            String
  category        String
  source          String
  aggregateType   String?
  aggregateId     String?
  orderId         String?
  purchaseOrderId String?
  amount          Decimal        @db.Decimal(12, 2)
  currency        String         @default("ILS")
  debit           Decimal?       @db.Decimal(12, 2)
  credit          Decimal?       @db.Decimal(12, 2)
  description     String?
  metadata        Json?
  order           Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([entryDate, type])
  @@index([category, entryDate])
  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([aggregateType, aggregateId])
}

model BlogAuthor {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  title     String?
  bio       String?
  imageUrl  String?
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogCategory {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  sortOrder   Int        @default(0)
  posts       BlogPost[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BlogTag {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  title                String
  excerpt              String
  bodyMarkdown         String
  status               BlogPostStatus @default(DRAFT)
  publishedAt          DateTime?
  heroImageUrl         String?
  heroImageAlt         String?
  seoTitle             String?
  seoDescription       String?
  featured             Boolean        @default(false)
  authorId             String?
  categoryId           String?
  createdByAdminUserId String?
  updatedByAdminUserId String?
  author               BlogAuthor?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category             BlogCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByAdminUser   AdminUser?     @relation("BlogPostCreatedBy", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  updatedByAdminUser   AdminUser?     @relation("BlogPostUpdatedBy", fields: [updatedByAdminUserId], references: [id], onDelete: SetNull)
  tags                 BlogTag[]
  relatedProducts      Product[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([status, publishedAt])
  @@index([featured, status, publishedAt])
  @@index([authorId])
  @@index([categoryId])
  @@index([createdByAdminUserId])
  @@index([updatedByAdminUserId])
}

model Role {
  id          String            @id @default(cuid())
  name        String            @unique
  permissions AdminPermission[]
  adminUsers  AdminUser[]
}

model AdminUser {
  id                    String         @id @default(cuid())
  userId                String?        @unique
  roleId                String
  name                  String
  email                 String         @unique
  passwordHash          String?
  disabledAt            DateTime?
  role                  Role           @relation(fields: [roleId], references: [id])
  user                  User?          @relation(fields: [userId], references: [id])
  auditLogs             AuditLog[]
  blogPostsCreated      BlogPost[]     @relation("BlogPostCreatedBy")
  blogPostsUpdated      BlogPost[]     @relation("BlogPostUpdatedBy")
  customerNotes         CustomerNote[]
  assignedCustomerTasks CustomerTask[]
  createdAt             DateTime       @default(now())

  @@index([disabledAt])
}

model AuditLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])
  createdAt   DateTime   @default(now())
}

model WebhookEvent {
  id          String        @id @default(cuid())
  provider    String
  eventType   String
  externalId  String
  status      WebhookStatus @default(RECEIVED)
  payload     Json
  rawBodyHash String?
  receivedAt  DateTime      @default(now())
  processedAt DateTime?

  @@unique([provider, externalId])
  @@index([provider, rawBodyHash])
}

model OutboxEvent {
  id             String            @id @default(cuid())
  type           String
  aggregateType  String?
  aggregateId    String?
  payload        Json
  status         OutboxEventStatus @default(PENDING)
  idempotencyKey String?           @unique
  availableAt    DateTime          @default(now())
  publishedAt    DateTime?
  processedAt    DateTime?
  attempts       Int               @default(0)
  lastError      String?
  jobRuns        JobRun[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, availableAt])
  @@index([type])
  @@index([aggregateType, aggregateId])
}

model JobRun {
  id            String       @id @default(cuid())
  name          String
  status        JobRunStatus @default(RUNNING)
  outboxEventId String?
  attempts      Int          @default(0)
  metadata      Json?
  lastError     String?
  startedAt     DateTime     @default(now())
  finishedAt    DateTime?
  outboxEvent   OutboxEvent? @relation(fields: [outboxEventId], references: [id], onDelete: SetNull)

  @@index([name, status])
  @@index([outboxEventId])
}

model IntegrationJob {
  id          String    @id @default(cuid())
  provider    String
  jobType     String
  status      String
  payload     Json?
  attempts    Int       @default(0)
  lastError   String?
  scheduledAt DateTime  @default(now())
  finishedAt  DateTime?
}

model UserFeedback {
  id         String    @id @default(cuid())
  message    String
  email      String?
  url        String?
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([createdAt])
}
