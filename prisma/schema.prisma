  id         String          @id @default(cuid())
  customerId String
  segmentId  String
  reason     String?
  score      Int             @default(0)
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  segment    CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([customerId, segmentId])
  @@index([segmentId, score])
}

model Campaign {
  id                String                     @id @default(cuid())
  key               String                     @unique
  name              String
  channel           String
  status            String                     @default("DRAFT")
  objective         String?
  segmentId         String?
  budget            Decimal?                   @db.Decimal(12, 2)
  startsAt          DateTime?
  endsAt            DateTime?
  metadata          Json?
  segment           CustomerSegment?           @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  audienceSnapshots CampaignAudienceSnapshot[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([status, startsAt])
  @@index([segmentId])
}

model CampaignAudienceSnapshot {
  id         String    @id @default(cuid())
  campaignId String
  customerId String?
  size       Int       @default(0)
  snapshot   Json
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([campaignId, createdAt])
  @@index([customerId])
}

/// A multi-step marketing automation. Customers are enrolled (e.g. from a
/// segment) and advanced step-by-step on a scheduled tick.
model Journey {
  id          String              @id @default(cuid())
  key         String              @unique
  name        String
  description String?
  /// segment_entered | manual
  triggerType String              @default("manual")
  segmentId   String?
  /// DRAFT | ACTIVE | ARCHIVED
  status      String              @default("DRAFT")
  metadata    Json?
  segment     CustomerSegment?    @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  steps       JourneyStep[]
  enrollments JourneyEnrollment[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
  @@index([segmentId])
}

/// One ordered step of a journey. `delayHours` is the wait before this step runs
/// (measured from the previous step / enrollment).
model JourneyStep {
  id           String  @id @default(cuid())
  journeyId    String
  stepOrder    Int
  /// send_email | add_tag | wait
  actionType   String
  delayHours   Int     @default(0)
  actionConfig Json?
  journey      Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, stepOrder])
  @@index([journeyId])
}

/// A customer's progress through a journey. `currentStepOrder` is the order of
/// the last completed step (0 = not started); `nextRunAt` is when the next step
/// is due.
model JourneyEnrollment {
  id               String    @id @default(cuid())
  journeyId        String
  customerId       String
  /// ACTIVE | COMPLETED | CANCELLED
  status           String    @default("ACTIVE")
  currentStepOrder Int       @default(0)
  nextRunAt        DateTime?
  enrolledAt       DateTime  @default(now())
  completedAt      DateTime?
  journey          Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([journeyId, customerId])
  @@index([status, nextRunAt])
  @@index([customerId])
}

model Vendor {
  id             String                @id @default(cuid())
  key            String                @unique
  name           String
  contactEmail   String?
  phone          String?
  website        String?
  paymentTerms   String?
  leadTimeDays   Int                   @default(14)
  status         String                @default("ACTIVE")
  metadata       Json?
  purchaseOrders PurchaseOrder[]
  costSnapshots  ProductCostSnapshot[]
  invoices       VendorInvoice[]
  payments       VendorPayment[]
  portalTokens   VendorPortalToken[]
  requisitions   PurchaseRequisition[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status, name])
}

/// A purchase requisition awaiting approval before it becomes a PO (P2P-001).
/// Requisitions at or above an approval threshold need explicit sign-off; below
/// it they auto-approve. An approved requisition converts into a PurchaseOrder.
model PurchaseRequisition {
  id                String                    @id @default(cuid())
  requisitionNumber String                    @unique
  vendorId          String?
  /// DRAFT | PENDING_APPROVAL | APPROVED | REJECTED | CONVERTED
  status            String                    @default("DRAFT")
  category          String?
  notes             String?
  estimatedTotal    Decimal                   @default(0) @db.Decimal(12, 2)
  requestedById     String?
  approvedById      String?
  approvedAt        DateTime?
  rejectedReason    String?
  purchaseOrderId   String?
  vendor            Vendor?                   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  lines             PurchaseRequisitionLine[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([status])
  @@index([vendorId])
}

model PurchaseRequisitionLine {
  id            String              @id @default(cuid())
  requisitionId String
  description   String
  sku           String?
  quantity      Int
  unitCost      Decimal             @db.Decimal(12, 2)
  totalCost     Decimal             @db.Decimal(12, 2)
  requisition   PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([requisitionId])
}

/// A revocable magic-link token granting a vendor read-only portal access (POR-002).
model VendorPortalToken {
  id         String    @id @default(cuid())
  vendorId   String
  token      String    @unique
  label      String?
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  vendor     Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, isActive])
}

model PurchaseOrder {
  id                   String               @id @default(cuid())
  poNumber             String               @unique
  vendorId             String
  status               String               @default("DRAFT")
  currency             String               @default("ILS")
  subtotal             Decimal              @default(0) @db.Decimal(12, 2)
  shippingTotal        Decimal              @default(0) @db.Decimal(12, 2)
  taxTotal             Decimal              @default(0) @db.Decimal(12, 2)
  total                Decimal              @default(0) @db.Decimal(12, 2)
  expectedAt           DateTime?
  orderedAt            DateTime?
  receivedAt           DateTime?
  notes                String?
  vendor               Vendor               @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items                PurchaseOrderItem[]
  receipts             GoodsReceipt[]
  financeLedgerEntries FinanceLedgerEntry[]
  vendorInvoices       VendorInvoice[]
  landedCosts          LandedCost[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([vendorId, status])
  @@index([status, expectedAt])
}

/// An extra acquisition cost (freight/customs/insurance) for a received PO,
/// capitalized into the receipt's cost layers on apply (P2P-008). Allocation
/// basis is by layer VALUE or QUANTITY.
model LandedCost {
  id              String        @id @default(cuid())
  purchaseOrderId String
  description     String
  amount          Decimal       @db.Decimal(12, 2)
  /// VALUE | QUANTITY
  basis           String        @default("VALUE")
  /// DRAFT | APPLIED
  status          String        @default("DRAFT")
  appliedAt       DateTime?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
}

model PurchaseOrderItem {
  id                 String                @id @default(cuid())
  purchaseOrderId    String
  productId          String?
  variantId          String?
  description        String
  sku                String?
  quantity           Int
  unitCost           Decimal               @db.Decimal(12, 2)
  totalCost          Decimal               @db.Decimal(12, 2)
  receivedQuantity   Int                   @default(0)
  purchaseOrder      PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product            Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant            ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  receipts           GoodsReceipt[]
  costSnapshots      ProductCostSnapshot[]
  vendorInvoiceLines VendorInvoiceLine[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([variantId])
}

model GoodsReceipt {
  id                  String             @id @default(cuid())
  purchaseOrderId     String
  purchaseOrderItemId String?
  variantId           String?
  branchId            String?
  quantity            Int
  receivedAt          DateTime           @default(now())
  reference           String?
  notes               String?
  purchaseOrder       PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)
  variant             ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  branch              Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId, receivedAt])
  @@index([purchaseOrderItemId])
  @@index([variantId])
  @@index([branchId])
}

model ProductCostSnapshot {
  id                  String             @id @default(cuid())
  productId           String
  variantId           String?
  vendorId            String?
  purchaseOrderItemId String?
  unitCost            Decimal            @db.Decimal(12, 2)
  currency            String             @default("ILS")
  effectiveAt         DateTime           @default(now())
  source              String             @default("manual")
  metadata            Json?
  product             Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant             ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  vendor              Vendor?            @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)

  @@index([productId, effectiveAt])
  @@index([variantId, effectiveAt])
  @@index([vendorId])
}

/// Double-entry chart of accounts (FIN-GL-001). One row per ledger account.
/// A managerial cost/profit center (FIN-CO-001). A CO layer separate from the
/// financial GL: revenue/expense entries are booked per center for
/// profitability and budget-variance reporting.
model CostCenter {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  /// COST | PROFIT
  kind          String      @default("COST")
  monthlyBudget Decimal     @default(0) @db.Decimal(14, 2)
  isActive      Boolean     @default(true)
  entries       CostEntry[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([isActive])
}

/// A revenue/expense entry attributed to a cost center for a period (YYYY-MM).
model CostEntry {
  id           String     @id @default(cuid())
  costCenterId String
  /// YYYY-MM
  period       String
  /// REVENUE | EXPENSE
  kind         String
  amount       Decimal    @db.Decimal(14, 2)
  description  String?
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([costCenterId, period])
}

/// An AI-extracted draft from a pasted vendor-invoice document (AI-004,
/// Document-AI). Read-only extraction for human review before creating AP.
model DocumentExtraction {
  id            String   @id @default(cuid())
  vendorName    String?
  invoiceNumber String?
  invoiceDate   String?
  currency      String?
  total         Decimal? @db.Decimal(14, 2)
  /// parsed lines as "description | quantity | unitCost" (one per line)
  linesText     String?
  source        String   @default("ai")
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

/// An effective-dated exchange rate to the base currency (ILS) for multi-currency
/// accounting and FX revaluation (FIN-GL-004). rateToBase = base units per 1
/// unit of `currency`. Rates are operator-entered — verify against a source.
model ExchangeRate {
  id            String   @id @default(cuid())
  currency      String
  rateToBase    Decimal  @db.Decimal(18, 6)
  effectiveDate DateTime @db.Date
  createdAt     DateTime @default(now())

  @@unique([currency, effectiveDate])
  @@index([currency, effectiveDate])
}

model LedgerAccount {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  /// ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  type        String
  /// DEBIT | CREDIT — the side that increases this account.
  normalSide  String
  parentId    String?
  isActive    Boolean         @default(true)
  description String?
  parent      LedgerAccount?  @relation("LedgerAccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    LedgerAccount[] @relation("LedgerAccountHierarchy")
  lines       JournalLine[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([type, code])
  @@index([parentId])
}

/// A fiscal accounting period (one calendar month). When CLOSED, the GL rejects
/// new postings dated within it (PRIN-003) and net income has been closed to
/// retained earnings via the linked closing entry (FIN-RPT-002).
model FiscalPeriod {
  id             String    @id @default(cuid())
  year           Int
  month          Int
  /// OPEN | CLOSED
  status         String    @default("OPEN")
  closingEntryId String?   @unique
  closedAt       DateTime?
  closedById     String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([year, month])
  @@index([status])
}

/// An imported bank-statement line, reconciled against the GL cash account.
/// `amount` is signed: positive is an inflow (deposit), negative an outflow.
model BankStatementLine {
  id                    String   @id @default(cuid())
  statementDate         DateTime @db.Date
  description           String
  amount                Decimal  @db.Decimal(14, 2)
  reference             String?
  currency              String   @default("ILS")
  /// UNMATCHED | MATCHED | IGNORED
  status                String   @default("UNMATCHED")
  matchedJournalEntryId String?  @unique
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, statementDate])
}

/// A balanced double-entry journal entry (Σdebit = Σcredit), append-only.
/// Corrections are made by posting a reversing entry, never by mutation.
model JournalEntry {
  id              String        @id @default(cuid())
  entryNumber     String        @unique
  entryDate       DateTime      @db.Date
  memo            String?
  /// e.g. "sale" | "purchase_receipt" | "payment" | "manual" | "reversal"
  source          String
  /// DRAFT | POSTED | REVERSED
  status          String        @default("POSTED")
  currency        String        @default("ILS")
  aggregateType   String?
  aggregateId     String?
  orderId         String?
  purchaseOrderId String?
  reversalOfId    String?       @unique
  postedById      String?
  /// owning legal entity (ENT); null = the base entity
  entityId        String?
  metadata        Json?
  lines           JournalLine[]
  reversalOf      JournalEntry? @relation("JournalEntryReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversedBy      JournalEntry? @relation("JournalEntryReversal")
  entity          LegalEntity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([entryDate, source])
  @@index([status, entryDate])
  @@index([aggregateType, aggregateId])
  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([entityId])
}

/// One debit-or-credit posting line of a JournalEntry.
model JournalLine {
  id             String        @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal       @default(0) @db.Decimal(14, 2)
  credit         Decimal       @default(0) @db.Decimal(14, 2)
  memo           String?
  branchId       String?
  metadata       Json?
  journalEntry   JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([branchId])
}

/// Accounts Payable: a supplier invoice, optionally matched to a purchase order.
model VendorInvoice {
  id              String                    @id @default(cuid())
  invoiceNumber   String
  vendorId        String
  purchaseOrderId String?
  /// DRAFT | MATCHED | VARIANCE | APPROVED | PARTIALLY_PAID | PAID | CANCELLED
  status          String                    @default("DRAFT")
  currency        String                    @default("ILS")
  subtotal        Decimal                   @default(0) @db.Decimal(14, 2)
  taxTotal        Decimal                   @default(0) @db.Decimal(14, 2)
  total           Decimal                   @default(0) @db.Decimal(14, 2)
  paidTotal       Decimal                   @default(0) @db.Decimal(14, 2)
  invoiceDate     DateTime                  @db.Date
  dueDate         DateTime?                 @db.Date
  approvedAt      DateTime?
  /// admin user who entered the invoice (for SoD: creator != approver, P2P-009)
  createdById     String?
  notes           String?
  metadata        Json?
  vendor          Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseOrder   PurchaseOrder?            @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  lines           VendorInvoiceLine[]
  allocations     VendorPaymentAllocation[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([vendorId, invoiceNumber])
  @@index([status, dueDate])
  @@index([purchaseOrderId])
}

model VendorInvoiceLine {
  id                  String             @id @default(cuid())
  vendorInvoiceId     String
  purchaseOrderItemId String?
  description         String
  quantity            Int
  unitCost            Decimal            @db.Decimal(14, 2)
  lineTotal           Decimal            @db.Decimal(14, 2)
  vendorInvoice       VendorInvoice      @relation(fields: [vendorInvoiceId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)

  @@index([vendorInvoiceId])
  @@index([purchaseOrderItemId])
}

model VendorPayment {
  id          String                    @id @default(cuid())
  vendorId    String
  amount      Decimal                   @db.Decimal(14, 2)
  /// tax withheld at source (ניכוי מס במקור) — feeds form 856
  withheldTax Decimal                   @default(0) @db.Decimal(14, 2)
  currency    String                    @default("ILS")
  method      String                    @default("bank_transfer")
  reference   String?
  paidAt      DateTime                  @default(now())
  notes       String?
  vendor      Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  allocations VendorPaymentAllocation[]
  createdAt   DateTime                  @default(now())

  @@index([vendorId, paidAt])
}

/// Allocation of a vendor payment to a specific invoice (supports split payments).
model VendorPaymentAllocation {
  id              String        @id @default(cuid())
  vendorPaymentId String
  vendorInvoiceId String
  amount          Decimal       @db.Decimal(14, 2)
  vendorPayment   VendorPayment @relation(fields: [vendorPaymentId], references: [id], onDelete: Cascade)
  vendorInvoice   VendorInvoice @relation(fields: [vendorInvoiceId], references: [id], onDelete: Restrict)

  @@index([vendorPaymentId])
  @@index([vendorInvoiceId])
}

/// Accounts Receivable: a customer invoice document, optionally from an order.
model CustomerInvoice {
  id               String                      @id @default(cuid())
  invoiceNumber    String                      @unique
  customerId       String?
  orderId          String?
  /// DRAFT | ISSUED | PARTIALLY_PAID | PAID | CANCELLED
  status           String                      @default("DRAFT")
  currency         String                      @default("ILS")
  subtotal         Decimal                     @default(0) @db.Decimal(14, 2)
  taxTotal         Decimal                     @default(0) @db.Decimal(14, 2)
  total            Decimal                     @default(0) @db.Decimal(14, 2)
  paidTotal        Decimal                     @default(0) @db.Decimal(14, 2)
  invoiceDate      DateTime                    @db.Date
  dueDate          DateTime?                   @db.Date
  issuedAt         DateTime?
  /// Israeli "חשבונית ישראל" allocation number (מספר הקצאה) from SHAAM
  allocationNumber String?
  /// NOT_REQUIRED | REQUIRED | ASSIGNED
  allocationStatus String                      @default("NOT_REQUIRED")
  notes            String?
  metadata         Json?
  customer         Customer?                   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order            Order?                      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  lines            CustomerInvoiceLine[]
  allocations      CustomerReceiptAllocation[]
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([status, dueDate])
  @@index([customerId])
  @@index([orderId])
}

model CustomerInvoiceLine {
  id                String          @id @default(cuid())
  customerInvoiceId String
  orderItemId       String?
  description       String
  quantity          Int
  unitPrice         Decimal         @db.Decimal(14, 2)
  lineTotal         Decimal         @db.Decimal(14, 2)
  customerInvoice   CustomerInvoice @relation(fields: [customerInvoiceId], references: [id], onDelete: Cascade)

  @@index([customerInvoiceId])
}

/// A logged dunning (collection) follow-up on an overdue customer invoice
/// (FIN-AR-001 dunning). Records the escalation level and a note.
model DunningAction {
  id                String   @id @default(cuid())
  customerInvoiceId String
  level             Int
  note              String?
  createdAt         DateTime @default(now())

  @@index([customerInvoiceId, createdAt])
}

model CustomerReceipt {
  id          String                      @id @default(cuid())
  customerId  String?
  amount      Decimal                     @db.Decimal(14, 2)
  currency    String                      @default("ILS")
  method      String                      @default("card")
  reference   String?
  receivedAt  DateTime                    @default(now())
  notes       String?
  customer    Customer?                   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  allocations CustomerReceiptAllocation[]
  createdAt   DateTime                    @default(now())

  @@index([customerId, receivedAt])
}

/// Allocation of a customer receipt to a specific invoice (supports split receipts).
model CustomerReceiptAllocation {
  id                String          @id @default(cuid())
  customerReceiptId String
  customerInvoiceId String
  amount            Decimal         @db.Decimal(14, 2)
  customerReceipt   CustomerReceipt @relation(fields: [customerReceiptId], references: [id], onDelete: Cascade)
  customerInvoice   CustomerInvoice @relation(fields: [customerInvoiceId], references: [id], onDelete: Restrict)

  @@index([customerReceiptId])
  @@index([customerInvoiceId])
}

/// CRM sales pipeline lead (CRM-SAL-001).
model Lead {
  id                  String        @id @default(cuid())
  name                String
  email               String?
  phone               String?
  /// manual | web | referral | campaign
  source              String        @default("manual")
  /// NEW | QUALIFIED | CONVERTED | DISQUALIFIED
  status              String        @default("NEW")
  customerId          String?
  assignedAdminUserId String?
  notes               String?
  metadata            Json?
  opportunities       Opportunity[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([customerId])
}

/// CRM sales opportunity (CRM-SAL-001/003).
model Opportunity {
  id                  String    @id @default(cuid())
  title               String
  /// QUALIFIED | PROPOSAL | NEGOTIATION | WON | LOST
  stage               String    @default("QUALIFIED")
  /// OPEN | WON | LOST
  status              String    @default("OPEN")
  amount              Decimal   @default(0) @db.Decimal(14, 2)
  currency            String    @default("ILS")
  /// 0–100 win probability for the weighted pipeline.
  probability         Int       @default(0)
  expectedCloseDate   DateTime? @db.Date
  customerId          String?
  leadId              String?
  assignedAdminUserId String?
  notes               String?
  metadata            Json?
  closedAt            DateTime?
  lead                Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quotes              Quote[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status, stage])
  @@index([customerId])
  @@index([leadId])
  @@index([expectedCloseDate])
}

/// A unified CRM interaction on a customer/lead/opportunity timeline
/// (CRM-SAL-004): calls, emails, meetings, notes and tasks in one log.
model CrmActivity {
  id                   String   @id @default(cuid())
  /// CALL | EMAIL | MEETING | NOTE | TASK
  type                 String   @default("NOTE")
  subject              String
  body                 String?
  occurredAt           DateTime @default(now())
  customerId           String?
  leadId               String?
  opportunityId        String?
  createdByAdminUserId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([customerId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([opportunityId, occurredAt])
  @@index([occurredAt])
}

/// CRM quote / proposal (CRM-SAL-002).
model Quote {
  id            String       @id @default(cuid())
  quoteNumber   String       @unique
  opportunityId String?
  customerId    String?
  /// DRAFT | SENT | ACCEPTED | DECLINED | EXPIRED
  status        String       @default("DRAFT")
  currency      String       @default("ILS")
  subtotal      Decimal      @default(0) @db.Decimal(14, 2)
  taxTotal      Decimal      @default(0) @db.Decimal(14, 2)
  total         Decimal      @default(0) @db.Decimal(14, 2)
  validUntil    DateTime?    @db.Date
  notes         String?
  metadata      Json?
  sentAt        DateTime?
  decidedAt     DateTime?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  lines         QuoteLine[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, validUntil])
  @@index([opportunityId])
  @@index([customerId])
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(14, 2)
  lineTotal   Decimal @db.Decimal(14, 2)
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

/// Immutable cost layer per goods receipt, for FIFO / weighted-average
/// inventory valuation (INV-002). Append-only; never mutated.
model ItemCostLayer {
  id         String   @id @default(cuid())
  branchId   String
  variantId  String
  unitCost   Decimal  @db.Decimal(14, 2)
  quantity   Int
  sourceType String   @default("purchase_receipt")
  sourceId   String?
  currency   String   @default("ILS")
  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([branchId, variantId, receivedAt])
  @@index([variantId])
}

model FinanceLedgerEntry {
  id              String         @id @default(cuid())
  entryDate       DateTime       @db.Date
  type            String
  category        String
  source          String
  aggregateType   String?
  aggregateId     String?
  orderId         String?
  purchaseOrderId String?
  amount          Decimal        @db.Decimal(12, 2)
  currency        String         @default("ILS")
  debit           Decimal?       @db.Decimal(12, 2)
  credit          Decimal?       @db.Decimal(12, 2)
  description     String?
  metadata        Json?
  order           Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([entryDate, type])
  @@index([category, entryDate])
  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([aggregateType, aggregateId])
}

model BlogAuthor {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  title     String?
  bio       String?
  imageUrl  String?
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogCategory {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  sortOrder   Int        @default(0)
  posts       BlogPost[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BlogTag {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  title                String
  excerpt              String
  bodyMarkdown         String
  status               BlogPostStatus @default(DRAFT)
  publishedAt          DateTime?
  heroImageUrl         String?
  heroImageAlt         String?
  seoTitle             String?
  seoDescription       String?
  featured             Boolean        @default(false)
  authorId             String?
  categoryId           String?
  createdByAdminUserId String?
  updatedByAdminUserId String?
  author               BlogAuthor?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category             BlogCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByAdminUser   AdminUser?     @relation("BlogPostCreatedBy", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  updatedByAdminUser   AdminUser?     @relation("BlogPostUpdatedBy", fields: [updatedByAdminUserId], references: [id], onDelete: SetNull)
  tags                 BlogTag[]
  relatedProducts      Product[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([status, publishedAt])
  @@index([featured, status, publishedAt])
  @@index([authorId])
  @@index([categoryId])
  @@index([createdByAdminUserId])
  @@index([updatedByAdminUserId])
}

model Role {
  id          String            @id @default(cuid())
  name        String            @unique
  permissions AdminPermission[]
  adminUsers  AdminUser[]
}

model AdminUser {
  id                         String              @id @default(cuid())
  userId                     String?             @unique
  roleId                     String
  name                       String
  email                      String              @unique
  passwordHash               String?
  disabledAt                 DateTime?
  totpSecretEncrypted        String?
  totpEnabledAt              DateTime?
  totpPendingSecretEncrypted String?
  totpPendingExpiresAt       DateTime?
  role                       Role                @relation(fields: [roleId], references: [id])
  user                       User?               @relation(fields: [userId], references: [id])
  auditLogs                  AuditLog[]
  blogPostsCreated           BlogPost[]          @relation("BlogPostCreatedBy")
  blogPostsUpdated           BlogPost[]          @relation("BlogPostUpdatedBy")
  customerNotes              CustomerNote[]
  assignedCustomerTasks      CustomerTask[]
  recoveryCodes              AdminRecoveryCode[]
  createdAt                  DateTime            @default(now())

  @@index([disabledAt])
}

// ADR 0005 (docs/DECISIONS.md): mandatory admin TOTP MFA. Recovery codes are
// operational working state, not evidentiary truth (unlike AuditLog) — ADR
// 0004's immutability triggers deliberately exclude this table, matching the
// existing OutboxEvent/ItemCostLayer carve-out. Regeneration hard-deletes all
// prior rows for the admin; the AuditLog row on generate/use is the durable
// evidence trail.
model AdminRecoveryCode {
  id          String    @id @default(cuid())
  adminUserId String
  codeHash    String
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
}

model AuditLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])
  createdAt   DateTime   @default(now())
}

model WebhookEvent {
  id          String        @id @default(cuid())
  provider    String
  eventType   String
  externalId  String
  status      WebhookStatus @default(RECEIVED)
  payload     Json
  rawBodyHash String?
  receivedAt  DateTime      @default(now())
  processedAt DateTime?

  @@unique([provider, externalId])
  @@index([provider, rawBodyHash])
}

/// ADR 0007: a durable record that a business invariant is currently
/// violated, at risk, or awaiting review. Not a log line. Acknowledgment
/// (operator saw it) is distinct from resolution (invariant no longer
/// violated).
model OperationalAlert {
  id               String    @id @default(cuid())
  /// Dedup identity for the violated invariant instance.
  alertKey         String    @unique
  /// MONEY | INVENTORY | SECURITY | CUSTOMER_COMMUNICATION | OUTBOX | ANALYTICS | SYSTEM
  class            String
  /// P0 | P1 | P2
  severity         String
  /// OPEN | ACKNOWLEDGED | RESOLVED | SUPPRESSED
  status           String    @default("OPEN")
  invariant        String
  message          String
  entityType       String?
  entityId         String?
  measuredValue    String?
  thresholdValue   String?
  remediationHint  String?
  occurrenceCount  Int       @default(1)
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  acknowledgedAt   DateTime?
  acknowledgedById String?
  resolvedAt       DateTime?
  lastNotifiedAt   DateTime?
  notifyCount      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, severity])
  @@index([class, status])
}

model OutboxEvent {
  id             String            @id @default(cuid())
  type           String
  aggregateType  String?
  aggregateId    String?
  payload        Json
  status         OutboxEventStatus @default(PENDING)
  idempotencyKey String?           @unique
  availableAt    DateTime          @default(now())
  publishedAt    DateTime?
  processedAt    DateTime?
  attempts       Int               @default(0)
  lastError      String?
  jobRuns        JobRun[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, availableAt])
  @@index([type])
  @@index([aggregateType, aggregateId])
}

model JobRun {
  id            String       @id @default(cuid())
  name          String
  status        JobRunStatus @default(RUNNING)
  outboxEventId String?
  attempts      Int          @default(0)
  metadata      Json?
  lastError     String?
  startedAt     DateTime     @default(now())
  finishedAt    DateTime?
  outboxEvent   OutboxEvent? @relation(fields: [outboxEventId], references: [id], onDelete: SetNull)

  @@index([name, status])
  @@index([outboxEventId])
}

model IntegrationJob {
  id          String    @id @default(cuid())
  provider    String
  jobType     String
  status      String
  payload     Json?
  attempts    Int       @default(0)
  lastError   String?
  scheduledAt DateTime  @default(now())
  finishedAt  DateTime?
}

model UserFeedback {
  id         String    @id @default(cuid())
  message    String
  email      String?
  url        String?
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([createdAt])
}
