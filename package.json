{
  "name": "elysia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/verify-production-env.mjs && node scripts/convert-public-images-to-avif.mjs",
    "build": "next build",
    "benchmark:header": "tsx scripts/header-benchmark.ts",
    "benchmark:header:local": "tsx scripts/header-benchmark.ts --skip-external",
    "benchmark:site": "tsx scripts/benchmarks/site-benchmark.ts --replace-blocked",
    "benchmark:site:local": "tsx scripts/benchmarks/site-benchmark.ts --skip-external",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "dev": "next dev --turbopack",
    "e2e": "playwright test",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "images:avif": "node scripts/convert-public-images-to-avif.mjs",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "predev": "node scripts/convert-public-images-to-avif.mjs",
    "preview": "next build && next start",
    "production:readiness": "node scripts/verify-production-env.mjs --readiness",
    "smoke": "node scripts/smoke.mjs",
    "visual:qa": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/visual-qa-agent-browser.ps1",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm check && pnpm build && pnpm format:check",
    "verify:runtime": "pnpm smoke && pnpm e2e && pnpm visual:qa"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@ai-sdk/react": "^3.0.170",
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "^6.6.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.168",
    "animejs": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gsap": "^3.15.0",
    "lottie-web": "^5.13.0",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.31",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.5.0",
    "streamdown": "^2.5.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typesense": "^3.0.6",
    "use-stick-to-bottom": "^1.1.3",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.59.1",
    "@serwist/turbopack": "^9.5.11",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/ui": "^4.1.5",
    "agent-browser": "^0.26.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.12",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.6.0",
    "serwist": "^9.5.11",
    "sharp": "0.34.5",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vitest": "^4.1.5"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "hono": "4.12.18",
      "ip-address": "10.1.1",
      "mermaid>uuid": "14.0.0",
      "postcss": "8.5.12",
      "svix": "1.92.2"
    },
    "onlyBuiltDependencies": [
      "agent-browser",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
