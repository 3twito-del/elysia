{
  "name": "elysia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm copy:check && node scripts/verify-production-env.mjs && node scripts/vercel-production-migrate.mjs && node scripts/convert-public-images-to-avif.mjs --check",
    "build": "node scripts/build.mjs",
    "check": "pnpm copy:check && pnpm lint && pnpm typecheck && pnpm test",
    "catalog:intake": "tsx scripts/catalog-owner-intake.ts",
    "catalog:intake:apply": "tsx scripts/catalog-owner-intake-apply.ts",
    "catalog:intake:validate": "tsx scripts/catalog-owner-intake-validate.ts",
    "catalog:quality": "tsx scripts/catalog-quality-report.ts",
    "catalog:readiness": "tsx scripts/catalog-readiness-audit.ts",
    "copy:apply": "tsx scripts/site-copy.ts apply",
    "copy:check": "tsx scripts/site-copy.ts check",
    "copy:sync": "tsx scripts/site-copy.ts sync",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "e2e": "playwright test",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "gate:build": "node scripts/gates.mjs build",
    "gate:coherence": "node scripts/gates.mjs coherence",
    "gate:db": "node scripts/gates.mjs db",
    "gate:e2e": "node scripts/gates.mjs e2e",
    "gate:fix": "node scripts/gates.mjs fix",
    "gate:full": "node scripts/gates.mjs full",
    "gate:list": "node scripts/gates.mjs list",
    "gate:prod": "node scripts/gates.mjs prod",
    "gate:qa": "node scripts/gates.mjs qa",
    "gate:quick": "node scripts/gates.mjs quick",
    "gate:release": "node scripts/gates.mjs release",
    "gate:release-slice": "node scripts/gates.mjs release-slice",
    "gate:runtime": "node scripts/gates.mjs runtime",
    "gate:security": "node scripts/gates.mjs security",
    "gate:ship": "node scripts/gates.mjs ship",
    "gate:slice": "node scripts/gates.mjs release-slice",
    "gate:smoke": "node scripts/gates.mjs smoke",
