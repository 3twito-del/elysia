    "gate:visual": "node scripts/gates.mjs visual",
    "images:avif": "node scripts/convert-public-images-to-avif.mjs",
    "postinstall": "prisma generate",
    "prepare": "simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "next build && next start",
    "production:readiness": "node scripts/verify-production-env.mjs --readiness",
    "qa:performance": "tsx scripts/qa-site-audit.ts --performance-only",
    "qa:routes": "tsx scripts/qa-route-inventory.ts --check",
    "qa:site": "tsx scripts/qa-site-audit.ts",
    "release:scorecard": "tsx scripts/release-scorecard.ts",
    "release:slice-gate": "tsx scripts/release-slice-gate.ts",
    "shopify:dropship:doctor": "node scripts/shopify-dropship-doctor.mjs",
    "shopify:dropship:sync": "tsx scripts/sync-shopify-dropship-catalog.ts",
    "smoke": "node scripts/smoke.mjs",
    "visual:qa": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/visual-qa-agent-browser.ps1",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm check && pnpm build && pnpm format:check",
    "verify:fast": "pnpm lint && pnpm typecheck && pnpm test",
    "verify:full": "pnpm gate:release",
    "verify:runtime": "pnpm smoke && pnpm e2e && pnpm visual:qa",
    "vercel:env:upsert": "node scripts/vercel-env-upsert.mjs"
  },
