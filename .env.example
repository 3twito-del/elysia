# Copy this file to .env and fill provider credentials as needed.

AUTH_SECRET=""
DATABASE_URL="postgresql://postgres:password@localhost:5432/elysia"

# Internal admin bootstrap for `pnpm db:seed`
ADMIN_BOOTSTRAP_EMAIL="admin@elysia.local"
ADMIN_BOOTSTRAP_PASSWORD=""
ADMIN_BOOTSTRAP_NAME="Elysia Admin"

# ADR 0005: admin TOTP-secret encryption key (>=32 chars). Separate from
# AUTH_SECRET on purpose — rotate it independently; rotating it re-enrolls
# every admin (docs/RUNBOOKS.md §10). Falls back to an insecure dev-only key
# when unset locally.
ADMIN_TOTP_ENCRYPTION_KEY=""

# CardCom payment adapter
CARD_COM_TERMINAL=""
CARD_COM_API_NAME=""
CARD_COM_API_PASSWORD=""
CARD_COM_WEBHOOK_SECRET=""

# Cloudinary media adapter
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Notifications
# Choose one no-card transactional email provider for production:
# - RESEND_API_KEY: Resend free plan, production access after domain verification
# - BREVO_API_KEY: Brevo free plan, daily send limit
RESEND_API_KEY=""
BREVO_API_KEY=""
STORE_FROM_EMAIL="orders@elysia.local"
STORE_FROM_NAME="Elysia"
OPERATIONS_EMAIL=""
SMS_PROVIDER_API_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:orders@elysia.local"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Vercel runtime guards
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
CRON_SECRET=""
JOB_RUNNER_SECRET=""

# Typesense search adapter
TYPESENSE_API_KEY=""
TYPESENSE_HOST=""
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"

# Optional Shopify dropshipping backend. Disabled unless explicitly enabled.
SHOPIFY_DROPSHIP_ENABLED="false"
SHOPIFY_DROPSHIP_SYNC_ENABLED="false"
SHOPIFY_STORE_DOMAIN=""
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_ADMIN_ACCESS_TOKEN=""
SHOPIFY_WEBHOOK_SECRET=""
SHOPIFY_API_VERSION="2026-04"

# Optional direct Google AI Studio / Gemini API key for fallback/experiments
GOOGLE_GENERATIVE_AI_API_KEY=""

# Free-tier-first AI router. Leave AI_CHAT_MODEL empty for the router.
FREE_AI_PROVIDER_ORDER="cerebras,groq,cloudflare,google"
CEREBRAS_API_KEY=""
CEREBRAS_CHAT_MODEL="qwen-3-235b-a22b-instruct-2507"
GROQ_API_KEY=""
GROQ_CHAT_MODEL="llama-3.1-8b-instant"
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_API_TOKEN=""
CLOUDFLARE_CHAT_MODEL="@cf/zai-org/glm-4.7-flash"
CLOUDFLARE_EMBEDDING_MODEL="@cf/baai/bge-m3"

# Optional manual chat model override:
# - cerebras:qwen-3-235b-a22b-instruct-2507 uses CEREBRAS_API_KEY
# - groq:llama-3.1-8b-instant uses GROQ_API_KEY
# - cloudflare:@cf/zai-org/glm-4.7-flash uses Cloudflare account/token
# - google:gemini-2.5-flash-lite uses the direct Google key
# - openai/gpt-5.4 routes through Vercel AI Gateway
AI_CHAT_MODEL=""
AI_MAX_OUTPUT_TOKENS="500"
AI_INTENT_MAX_OUTPUT_TOKENS="128"
AI_DAILY_HARD_STOP="true"

AI_EMBEDDING_MODEL="cloudflare:@cf/baai/bge-m3"
AI_EMBEDDING_DIMENSIONS="1024"
AI_SEMANTIC_SEARCH_ENABLED="true"
VERCEL_OIDC_TOKEN=""
AI_GATEWAY_API_KEY=""
