# Copy this file to .env and fill provider credentials as needed.

AUTH_SECRET=""
DATABASE_URL="postgresql://postgres:password@localhost:5432/aphrodite"

# Internal admin bootstrap for `pnpm db:seed`
ADMIN_BOOTSTRAP_EMAIL="admin@aphrodite.local"
ADMIN_BOOTSTRAP_PASSWORD=""
ADMIN_BOOTSTRAP_NAME="Aphrodite Admin"

# CardCom payment adapter
CARD_COM_TERMINAL=""
CARD_COM_API_NAME=""
CARD_COM_API_PASSWORD=""

# Cloudinary media adapter
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Notifications
BREVO_API_KEY=""
STORE_FROM_EMAIL="orders@aphrodite.local"
STORE_FROM_NAME="Aphrodite"
OPERATIONS_EMAIL=""
RESEND_API_KEY=""
SMS_PROVIDER_API_KEY=""

# Typesense search adapter
TYPESENSE_API_KEY=""
TYPESENSE_HOST=""
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"

# Optional direct Google AI Studio / Gemini API key for experiments
GOOGLE_GENERATIVE_AI_API_KEY=""

# Vercel AI SDK / Gateway. Leave AI_CHAT_MODEL empty to use the app default.
AI_CHAT_MODEL="openai/gpt-5.4"
VERCEL_OIDC_TOKEN=""
