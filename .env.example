# Copy this file to .env and fill provider credentials as needed.

AUTH_SECRET=""
DATABASE_URL="postgresql://postgres:password@localhost:5432/aphrodite"

# Internal admin bootstrap for `pnpm db:seed`
ADMIN_BOOTSTRAP_EMAIL="admin@aphrodite.local"
ADMIN_BOOTSTRAP_PASSWORD=""
ADMIN_BOOTSTRAP_NAME="Aphrodite Admin"

# CardCom payment adapter
CARD_COM_TERMINAL=""
CARD_COM_API_NAME=""
CARD_COM_API_PASSWORD=""

# Cloudinary media adapter
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Notifications
# Choose one no-card transactional email provider for production:
# - RESEND_API_KEY: Resend free plan, production access after domain verification
# - BREVO_API_KEY: Brevo free plan, daily send limit
RESEND_API_KEY=""
BREVO_API_KEY=""
STORE_FROM_EMAIL="orders@aphrodite.local"
STORE_FROM_NAME="Aphrodite"
OPERATIONS_EMAIL=""
SMS_PROVIDER_API_KEY=""

# Typesense search adapter
TYPESENSE_API_KEY=""
TYPESENSE_HOST=""
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"

# Optional direct Google AI Studio / Gemini API key for experiments
GOOGLE_GENERATIVE_AI_API_KEY=""

# AI chat model override:
# - google:gemini-2.5-flash-lite uses the direct Google key below
# - openai/gpt-5.4 routes through Vercel AI Gateway
# Leave empty to use google:gemini-2.5-flash-lite when GOOGLE_GENERATIVE_AI_API_KEY exists.
AI_CHAT_MODEL="google:gemini-2.5-flash-lite"
VERCEL_OIDC_TOKEN=""
